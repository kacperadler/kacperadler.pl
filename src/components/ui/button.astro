---
import { Icon } from "astro-icon/components";

interface Props {
  class?: string;
  href?: string;
  icon?: string;
  size?: "md" | "sm";
  type?: "button" | "submit" | "reset";
  variant: "primary" | "ghost";
}

const {
  variant,
  href,
  type = "button",
  icon,
  size = "md",
  class: extraClass,
  ...rest
} = Astro.props;

const classes = ["btn", `btn-${variant}`, size === "sm" && "btn-sm", extraClass];
---

{
  href ? (
    <a href={href} class:list={classes} {...rest}>
      <slot />
      {icon && <Icon aria-hidden="true" class="btn-icon" name={icon} />}
      <span aria-hidden="true" class="btn-spinner" />
    </a>
  ) : (
    <button class:list={classes} type={type} {...rest}>
      <slot />
      {icon && <Icon aria-hidden="true" class="btn-icon" name={icon} />}
      <span aria-hidden="true" class="btn-spinner" />
    </button>
  )
}

<style>
  /* Canonical button - vocabulary mirrors the header .nav-cta:
   *   - --display family + tight letter-spacing
   *   - --v2-radius-sm so the silhouette harmonises with v2 panels
   *   - 0.25s ease unified transition covering bg/border/shadow +
   *     backdrop-filter (so the ghost glass-up animates smoothly)
   *
   * Hover model:
   *   - PRIMARY: 12% darken on bg + 4px --blue-wash ring (same ring
   *     used by .nav-cta:hover, so the language is one). No translateY.
   *   - GHOST: lifts into the same liquid-glass treatment as
   *     .hero-status / the header chrome - translucent --v2-panel,
   *     soft border, lit-edge inset, blur(20px) saturate(160%). Two
   *     glass surfaces, one hover vocabulary.
   *
   * Header keeps a hand-written .nav-cta in nav.astro because it has
   * the scrolled-state padding/font-size transitions baked in - those
   * don't fit a static component. */
  .btn {
    display: inline-flex;
    gap: 8px;
    align-items: center;
    font-family: var(--display);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: -0.01em;
    border-radius: var(--v2-radius-sm);
    transition:
      background 0.25s ease,
      color 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease,
      padding 0.25s ease,
      -webkit-backdrop-filter 0.25s ease,
      backdrop-filter 0.25s ease;
  }

  .btn :global(.btn-icon) {
    width: 14px;
    height: 14px;
  }

  /* Arrow zawija się dookoła: wylatuje w prawo, fade'uje, teleportuje
   * z prawej krawędzi na lewą podczas opacity 0, wraca do center.
   * 0% i 100% są identyczne ze stanem spoczynkowym, więc po
   * zakończeniu animacji nic nie wraca - strzałka po prostu
   * "przeleciała" raz na każdy hover. */
  .btn:hover :global(.btn-icon) {
    animation: btn-arrow-cycle 0.45s ease;
  }

  @keyframes btn-arrow-cycle {
    0% {
      opacity: 1;
      transform: translateX(0);
    }
    49% {
      opacity: 0;
      transform: translateX(14px);
    }
    50% {
      opacity: 0;
      transform: translateX(-14px);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .btn-primary {
    padding: 14px 22px;
    color: light-dark(var(--paper), var(--paper-2));
    background: var(--ink);
  }

  .btn-primary:hover {
    background: color-mix(in srgb, var(--ink) 88%, black);
    box-shadow: 0 0 0 4px var(--blue-wash);
  }

  .btn-ghost {
    padding: 14px 18px;
    color: var(--ink);
    background: transparent;
    border: 1px solid var(--v2-line);
  }

  .btn-ghost:hover {
    background: color-mix(in srgb, var(--v2-panel) 55%, transparent);
    border-color: color-mix(in srgb, var(--v2-line) 60%, transparent);
    box-shadow: inset 0 1px 0 light-dark(rgba(255, 255, 255, 0.6), rgba(255, 255, 255, 0.05));
    -webkit-backdrop-filter: saturate(160%) blur(20px);
    backdrop-filter: saturate(160%) blur(20px);
  }

  /* Compact variant for header CTA. Shrinks padding, keeps font-size /
   * letter-spacing / hover model identical so the silhouette reads as
   * the same family at a different scale. */
  .btn-sm.btn-primary {
    padding: 9px 16px;
  }

  .btn-sm.btn-ghost {
    padding: 9px 14px;
  }

  /* Disabled state - applied automatically when [disabled] is set or
   * when contact-form.ts toggles [data-state="submitting"]. Dims +
   * locks the cursor + cancels hover transforms so the button reads as
   * "wait, processing" without disappearing. */
  .btn[disabled],
  .btn[data-state="submitting"] {
    cursor: not-allowed;
    opacity: 0.6;
  }

  .btn[disabled]:hover :global(.btn-icon),
  .btn[data-state="submitting"]:hover :global(.btn-icon) {
    animation: none;
  }

  /* Pending/loading state - circular spinner replaces the icon when the
   * button enters [data-state="submitting"]. Hidden by default to avoid
   * visual noise; only renders when the state attribute is set, so
   * regular buttons don't carry a stray empty span. */
  .btn-spinner {
    box-sizing: border-box;
    display: none;
    flex-shrink: 0;
    width: 14px;
    height: 14px;
    border: 2px solid currentColor;
    border-right-color: transparent;
    border-radius: 50%;
  }

  .btn[data-state="submitting"] :global(.btn-icon) {
    display: none;
  }

  .btn[data-state="submitting"] .btn-spinner {
    display: inline-block;
    animation: btn-spinner-spin 0.8s linear infinite;
  }

  @keyframes btn-spinner-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .btn,
    .btn :global(.btn-icon) {
      transition: none;
    }
    .btn:hover :global(.btn-icon) {
      animation: none;
    }
    .btn[data-state="submitting"] .btn-spinner {
      animation: none;
    }
  }
</style>

---
import { Icon } from "astro-icon/components";

/* 3-state theme toggle: light | dark | system.
 *
 * Click handler is delegated on document so it survives ClientRouter
 * swaps. Sync of aria-pressed runs on first load AND on
 * astro:page-load so navigation between pages keeps the buttons in
 * sync with the current state. "system" mode just removes
 * <html data-theme>, letting `light-dark()` + `color-scheme: light dark`
 * follow prefers-color-scheme automatically. */
---

<div class="fab-stack" role="group" aria-label="Motyw">
  <button
    type="button"
    class="fab-btn"
    data-theme-mode="light"
    aria-pressed="false"
    aria-label="Motyw jasny"
    title="Jasny"
  >
    <Icon name="lucide:sun" aria-hidden="true" />
  </button>
  <button
    type="button"
    class="fab-btn"
    data-theme-mode="dark"
    aria-pressed="false"
    aria-label="Motyw ciemny"
    title="Ciemny"
  >
    <Icon name="lucide:moon" aria-hidden="true" />
  </button>
  <button
    type="button"
    class="fab-btn"
    data-theme-mode="system"
    aria-pressed="false"
    aria-label="Motyw systemowy"
    title="System"
  >
    <Icon name="lucide:monitor" aria-hidden="true" />
  </button>
</div>

<style>
  .fab-stack {
    position: fixed;
    right: 20px;
    bottom: 20px;
    z-index: 55;
    display: inline-flex;
    background: var(--card);
    border: 1px solid var(--line);
    box-shadow: 0 8px 24px -12px rgba(0, 0, 0, 0.18);
  }

  .fab-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    color: var(--muted);
    transition:
      color 0.15s ease,
      background 0.15s ease;
  }

  .fab-btn:hover {
    color: var(--ink);
  }

  .fab-btn[aria-pressed="true"] {
    color: var(--blue);
    background: var(--blue-wash);
  }

  .fab-btn :global(svg) {
    width: 16px;
    height: 16px;
  }

  @media (prefers-reduced-motion: reduce) {
    .fab-btn {
      transition: none;
    }
  }
</style>

<script>
  type ThemeMode = "light" | "dark" | "system";
  const THEME_KEY = "ka:theme";

  function readStored(): ThemeMode {
    try {
      const value = localStorage.getItem(THEME_KEY);
      return value === "light" || value === "dark" ? value : "system";
    } catch {
      return "system";
    }
  }

  function writeStored(value: ThemeMode): void {
    try {
      if (value === "system") {
        localStorage.removeItem(THEME_KEY);
      } else {
        localStorage.setItem(THEME_KEY, value);
      }
    } catch {
      // ignore (private mode, etc.)
    }
  }

  function applyTheme(value: ThemeMode): void {
    const root = document.documentElement;
    if (value === "light" || value === "dark") {
      root.dataset.theme = value;
    } else {
      delete root.dataset.theme;
    }
  }

  function syncPressed(): void {
    const active = readStored();
    const buttons = document.querySelectorAll<HTMLButtonElement>("[data-theme-mode]");
    for (const btn of buttons) {
      btn.setAttribute("aria-pressed", btn.dataset.themeMode === active ? "true" : "false");
    }
  }

  // Delegated click — survives ClientRouter swaps without re-attaching.
  document.addEventListener("click", (event) => {
    const target =
      event.target instanceof Element
        ? event.target.closest<HTMLElement>("[data-theme-mode]")
        : null;
    if (!target) {
      return;
    }
    const mode = target.dataset.themeMode;
    if (mode !== "light" && mode !== "dark" && mode !== "system") {
      return;
    }
    writeStored(mode);
    applyTheme(mode);
    syncPressed();
  });

  // Initial sync + re-sync after view transitions.
  syncPressed();
  document.addEventListener("astro:page-load", syncPressed);
</script>

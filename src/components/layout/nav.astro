---
import { Icon } from "astro-icon/components";
import Button from "@/components/ui/button.astro";
import { contactCta, primaryNav } from "@/data/navigation";
import { siteConfig } from "@/data/site-config";
---

<nav class="nav" aria-label="Główna nawigacja">
  <a href="/#top" class="brand" aria-label={`${siteConfig.name} - Strona główna`}>
    <span class="mark" aria-hidden="true">k</span>
    <span><b>Kacper</b> <em>Adler</em></span>
  </a>

  <div class="nav-links">
    {
      primaryNav.map((link) => (
        <a data-nav-link href={link.href}>
          {link.label}
        </a>
      ))
    }
  </div>

  <div class="nav-tail">
    <Button
      variant="primary"
      size="sm"
      href={contactCta.href}
      icon="lucide:arrow-right"
      data-nav-cta
    >
      {contactCta.label}
    </Button>

    <button
      type="button"
      class="menu-btn"
      data-menu-open
      aria-label="Otwórz menu"
      aria-controls="mobile-sheet"
      aria-expanded="false"
    >
      <Icon name="lucide:menu" aria-hidden="true" />
    </button>
  </div>
</nav>

<style>
  .nav {
    display: flex;
    gap: 16px;
    align-items: center;
    justify-content: space-between;
    max-width: var(--container);
    padding: 18px 24px;
    margin: 0 auto;
    transition: padding 0.25s ease;
  }

  .brand {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    font-family: var(--display);
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.01em;
    transition: font-size 0.25s ease;
  }

  .mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    font-family: var(--display);
    font-size: 13px;
    font-weight: 600;
    color: light-dark(var(--paper), #0f1116);
    background: var(--blue);
    box-shadow: 0 2px 6px rgba(30, 58, 95, 0.18);
    transition:
      width 0.25s ease,
      height 0.25s ease,
      font-size 0.25s ease;
  }

  .brand b {
    font-weight: 500;
  }

  .brand em {
    font-style: normal;
    font-weight: 400;
    color: var(--muted);
  }

  .nav-links {
    display: flex;
    gap: 6px;
    align-items: center;
  }

  .nav-links a {
    position: relative;
    padding: 10px 4px;
    margin: 0 10px;
    font-family: var(--display);
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-2);
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
  }

  .nav-links a::after {
    position: absolute;
    bottom: 4px;
    left: 0;
    width: 100%;
    height: 1.5px;
    content: "";
    background: var(--blue);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.45s cubic-bezier(0.65, 0, 0.35, 1);
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--ink);
  }

  .nav-links a:hover::after,
  .nav-links a.active::after {
    transform: scaleX(1);
  }

  .nav-tail {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  /* Active state for the contact CTA - applied by nav-active.ts when
   * the user scrolls into the contact section. Filled blue + ring tells
   * the visitor "you've arrived". Targeted via [data-nav-cta] so the
   * rule never leaks to other .btn-primary instances. */
  :global([data-nav-cta].active) {
    color: light-dark(var(--paper), #0f1116);
    background: var(--blue);
    box-shadow: 0 0 0 4px var(--blue-wash);
  }

  .menu-btn {
    display: none;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--ink);
    background: transparent;
    border: 1px solid var(--line);
  }

  .menu-btn :global(svg) {
    width: 18px;
    height: 18px;
  }

  /* Scrolled state - toggled by F5 script on the .nav-wrap parent. */
  :global(.nav-wrap.scrolled) .nav {
    padding: 10px 24px;
  }
  :global(.nav-wrap.scrolled) .brand {
    font-size: 14px;
  }
  :global(.nav-wrap.scrolled) .mark {
    width: 24px;
    height: 24px;
    font-size: 12px;
  }
  :global(.nav-wrap.scrolled) :global([data-nav-cta]) {
    padding: 7px 13px;
  }

  @media (max-width: 880px) {
    .nav-links {
      display: none;
    }
    .menu-btn {
      display: inline-flex;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav,
    .brand,
    .mark,
    .nav-links a,
    .nav-links a::after {
      transition: none;
    }
  }
</style>

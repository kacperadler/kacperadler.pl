---
import { Icon } from "astro-icon/components";
import Button from "@/components/ui/button.astro";
import { contactCta, primaryNav } from "@/data/navigation";
---

<div id="mobile-sheet" class="sheet" data-mobile-sheet aria-hidden="true" aria-label="Menu mobilne">
  <button type="button" class="sheet-close" data-menu-close aria-label="Zamknij menu">
    <Icon name="lucide:x" aria-hidden="true" />
  </button>

  <div class="sheet-content">
    <span class="status-pill">
      <span class="status-pill-dot" aria-hidden="true"></span>
      Otwarty na nowe współprace
    </span>

    <nav class="sheet-nav" aria-label="Menu główne">
      {
        primaryNav.map((link) => (
          <a class="sheet-link" data-sheet-link href={link.href}>
            <span>{link.label}</span>
            <Icon aria-hidden="true" name="lucide:arrow-right" />
          </a>
        ))
      }
    </nav>

    <Button
      class="sheet-cta"
      data-sheet-link
      href={contactCta.href}
      icon="lucide:arrow-right"
      size="md"
      variant="primary"
    >
      {contactCta.label}
    </Button>
  </div>
</div>

<style>
  /* Full-screen overlay. Zawsze renderowany w display: flex, ale w
   * stanie zamkniętym ukryty przez opacity + visibility + transform.
   * Dzięki temu transition działa w OBIE strony - open: fade-in +
   * slide-up; close: fade-out + slide-down. Visibility kicks in
   * immediately at open, ale na close ma `0s linear 0.3s` delay,
   * żeby element zniknął z accessibility tree dopiero PO zakończeniu
   * fade-out (inaczej snap'owałby). pointer-events: none gdy idle,
   * żeby nie łapał klików spod overlay'u. v2-only glass treatment
   * lives in v2-layout via body.v2-body .sheet override. */
  .sheet {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: flex;
    visibility: hidden;
    flex-direction: column;
    padding: 80px 24px 32px;
    pointer-events: none;
    background: var(--paper);
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.3s ease,
      transform 0.3s ease,
      visibility 0s linear 0.3s;
  }

  .sheet[data-mobile-sheet="open"] {
    visibility: visible;
    pointer-events: auto;
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity 0.3s ease,
      transform 0.3s ease,
      visibility 0s linear 0s;
  }

  .sheet-content {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 24px;
  }

  .sheet-close {
    position: absolute;
    top: 18px;
    right: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--ink);
    background: transparent;
    border: 1px solid var(--line);
    border-radius: var(--v2-radius-sm);
  }

  .sheet-close :global(svg) {
    width: 18px;
    height: 18px;
  }

  /* "Otwarty na nowe współprace" pill - lustro hero-status pill.
   * Daje powitanie + signal "available" zaraz po otwarciu menu. */
  .status-pill {
    display: inline-flex;
    gap: 8px;
    align-items: center;
    align-self: flex-start;
    padding: 6px 12px;
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--blue);
    background: var(--blue-wash);
    border-radius: var(--v2-radius-xs);
  }

  .status-pill-dot {
    width: 6px;
    height: 6px;
    background: var(--blue);
    border-radius: var(--v2-radius-full);
  }

  /* Nav links jako "menu listing" - tytuł po lewej, strzałka po
   * prawej. Strzałka idle muted, na hover ożywa do --blue i
   * przesuwa się 4px w prawo. */
  .sheet-nav {
    display: flex;
    flex-direction: column;
  }

  .sheet-link {
    display: flex;
    gap: 12px;
    align-items: center;
    justify-content: space-between;
    padding: 14px 0;
    font-family: var(--display);
    font-size: 22px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.01em;
    border-bottom: 1px solid var(--line);
    transition: color 0.2s ease;
  }

  .sheet-link :global(svg) {
    width: 18px;
    height: 18px;
    color: var(--muted);
    transition:
      color 0.2s ease,
      transform 0.2s ease;
  }

  .sheet-link:hover :global(svg),
  .sheet-link:focus-visible :global(svg) {
    color: var(--blue);
    transform: translateX(4px);
  }

  /* CTA: canonical Button, ale stretched do pełnej szerokości.
   * margin-top: auto pcha go do dołu sheetu, niezależnie od liczby
   * linków nav. */
  .sheet-cta {
    justify-content: center;
    margin-top: auto;
  }

  /* Button is inline-flex by default - need to make it full-width
   * inside the sheet without forking the canonical Button. */
  :global(.sheet-cta) {
    display: flex;
    width: 100%;
  }

  @media (prefers-reduced-motion: reduce) {
    .sheet,
    .sheet[data-mobile-sheet="open"] {
      transition: none;
    }

    .sheet-link,
    .sheet-link :global(svg) {
      transition: none;
    }
  }
</style>

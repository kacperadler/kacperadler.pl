---
import { siteConfig } from "@/data/site-config";
import { personSchema, websiteSchema } from "@/lib/seo";

interface Props {
  description?: string;
  noindex?: boolean;
  ogImage?: string;
  title?: string;
}

const {
  title,
  description = siteConfig.description,
  ogImage = siteConfig.ogImage,
  noindex = false,
} = Astro.props;

const fullTitle = title
  ? `${title} - ${siteConfig.name}`
  : `${siteConfig.name} - ${siteConfig.role}`;

const canonical = new URL(Astro.url.pathname, Astro.site ?? siteConfig.url).toString();
const ogImageUrl = new URL(ogImage, Astro.site ?? siteConfig.url).toString();
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

{noindex && <meta content="noindex, nofollow" name="robots" />}

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" sizes="any" />

<meta name="theme-color" content="#0a0c10" />

<link rel="preload" href="/fonts/Geist-Variable.woff2" as="font" type="font/woff2" crossorigin />
<link
  rel="preload"
  href="/fonts/GeistMono-Variable.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>

<meta property="og:type" content="website" />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:locale" content={siteConfig.locale.replace("-", "_")} />
<meta property="og:site_name" content={siteConfig.name} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<link rel="sitemap" href="/sitemap-index.xml" />

<script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
<script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

{
  /* Umami analytics, self-hosted at analytics.kacperadler.pl. PROD-only
   * so dev pageviews don't pollute the data.
   *
   * The script tag is injected via JS after window 'load' (via
   * requestIdleCallback with a 2.5s timeout fallback) instead of being
   * inlined in HTML head. That way the /api/send tracking ping happens
   * AFTER FCP/LCP and stays off Lighthouse's critical path - the
   * analytics roundtrip used to add ~270ms to "Maximum critical path
   * latency" with the script tag in head. astro:page-load reload re-
   * fires on every ClientRouter view transition (equivalent to the
   * data-astro-rerun attribute on a static script tag).
   *
   * is:inline so Astro doesn't try to process the script src; the
   * defer attribute on the injected tag keeps it non-blocking even
   * after load. data-do-not-track lets visitors who set DNT opt out
   * via Umami's own logic. */
  import.meta.env.PROD && (
    <script
      set:html={`
        (() => {
          const src = ${JSON.stringify(`${siteConfig.analytics.umamiUrl}/script.js`)};
          const id = ${JSON.stringify(siteConfig.analytics.umamiWebsiteId)};
          let loaded = false;
          function load() {
            if (loaded) return;
            loaded = true;
            const s = document.createElement('script');
            s.src = src;
            s.defer = true;
            s.dataset.websiteId = id;
            s.dataset.doNotTrack = 'true';
            document.head.appendChild(s);
          }
          if ('requestIdleCallback' in window) {
            requestIdleCallback(load, { timeout: 2500 });
          } else {
            addEventListener('load', () => setTimeout(load, 1500));
          }
          // ClientRouter view transitions swap the DOM but keep window state.
          // Umami's auto-init only runs once at first load, so subsequent
          // navigations need a manual track() to register the pageview.
          document.addEventListener('astro:page-load', () => {
            if (loaded) window.umami?.track();
          });
        })();
      `}
      is:inline
    />
  )
}

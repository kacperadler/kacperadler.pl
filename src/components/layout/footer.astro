---
import { Icon } from "astro-icon/components";
import { siteConfig } from "@/data/site-config";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/#top" class="brand" aria-label={`${siteConfig.name} - Strona główna`}>
          <span class="mark" aria-hidden="true">k</span>
          <span><b>Kacper</b> <em>Adler</em></span>
        </a>
        <p class="brand-tagline">
          Frontend Engineer. React, TypeScript, Astro - od architektury po deploy.
        </p>
      </div>

      <div class="footer-cols">
        <div class="footer-col">
          <h3 class="footer-col-title">Informacje</h3>
          <ul>
            <li>
              <a href="/polityka-prywatnosci">Polityka prywatności</a>
            </li>
            <li>
              <a href="/regulamin">Regulamin</a>
            </li>
          </ul>
        </div>

        <div class="footer-col">
          <h3 class="footer-col-title">Kontakt</h3>
          <ul>
            <li>
              <a href={`mailto:${siteConfig.email}`}>
                <Icon aria-hidden="true" name="lucide:mail" />
                <span>Email</span>
              </a>
            </li>
            <li>
              <a href={siteConfig.social.linkedin} rel="noopener" target="_blank">
                <Icon aria-hidden="true" name="lucide:linkedin" />
                <span>LinkedIn</span>
              </a>
            </li>
            <li>
              <a href={siteConfig.social.github} rel="noopener" target="_blank">
                <Icon aria-hidden="true" name="lucide:github" />
                <span>GitHub</span>
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {year} · kacperadler.pl</span>
    </div>
  </div>
</footer>

<style>
  /* Two-zone footer: brand + tagline on the left, two columns of
   * links on the right. Bottom row carries the copyright separated
   * by a hairline. v2-only glass treatment lives in v2-layout via
   * body.v2-body .site-footer override - v1 stays solid. */
  .site-footer {
    padding: 56px 0 28px;
    margin-top: 24px;
    border-top: 1px solid var(--line);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .brand {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    font-family: var(--display);
    font-size: 20px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  .mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    font-family: var(--display);
    font-size: 13px;
    font-weight: 600;
    color: light-dark(var(--paper), #0f1116);
    background: var(--blue);
    box-shadow: 0 2px 6px rgba(30, 58, 95, 0.18);
  }

  .brand b {
    font-weight: 500;
  }

  .brand em {
    font-style: normal;
    font-weight: 400;
    color: var(--muted);
  }

  .brand-tagline {
    max-width: 38ch;
    margin: 0;
    font-size: 14px;
    line-height: 1.6;
    color: var(--muted);
  }

  .footer-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .footer-col-title {
    margin: 0 0 14px;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .footer-col a {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    font-size: 14px;
    color: var(--ink-2);
    transition: color 0.2s ease;
  }

  .footer-col a :global(svg) {
    width: 16px;
    height: 16px;
    color: var(--muted);
    transition: color 0.2s ease;
  }

  .footer-col a:hover {
    color: var(--ink);
  }

  .footer-col a:hover :global(svg) {
    color: var(--blue);
  }

  /* Copyright row sits below the grid, separated by a soft hairline.
   * Single line on desktop, can wrap on small viewports. */
  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    justify-content: space-between;
    padding-top: 24px;
    margin-top: 48px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.04em;
    border-top: 1px solid var(--line);
  }

  @media (max-width: 880px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .footer-cols {
      gap: 24px;
    }

    .footer-bottom {
      margin-top: 32px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-col a,
    .footer-col a :global(svg) {
      transition: none;
    }
  }
</style>

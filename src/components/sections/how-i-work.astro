---
import SectionHead from "@/components/ui/section-head.astro";

interface FlowStep {
  badge: string;
  description: string;
  num: string;
  title: string;
}

const steps: readonly FlowStep[] = [
  {
    num: "01",
    title: "Zaczynamy od rozmowy.",
    description:
      "Krótkie spotkanie lub wymiana maili — opowiadasz, co chcesz zbudować i po co. Ja zadaję pytania, żeby zrozumieć Twój biznes, użytkowników i priorytety.",
    badge: "~ 30 min",
  },
  {
    num: "02",
    title: "Plan i realna wycena.",
    description:
      "Po rozmowie dostajesz od mnie krótki dokument: co robimy, w jakiej kolejności, ile to zajmie i ile kosztuje. Bez ukrytych kosztów, bez niespodzianek w trakcie.",
    badge: "2–3 dni",
  },
  {
    num: "03",
    title: "Budujemy krok po kroku.",
    description:
      "Pracuję w małych etapach — co tydzień widzisz postęp na działającej wersji strony, nie na screenach. Łatwiej wtedy reagować, jeśli coś idzie w niedobrą stronę.",
    badge: "podział na etapy",
  },
  {
    num: "04",
    title: "Twój feedback idzie do kodu.",
    description:
      "Nie musisz znać się na technologii. Mówisz „to powinno być szybsze”, „tu brakuje jasności”, „zmieńmy kolejność” — ja tłumaczę to na konkretne zmiany i pokazuję efekt.",
    badge: "na bieżąco",
  },
  {
    num: "05",
    title: "Wdrożenie i wsparcie po.",
    description:
      "Po odpaleniu projekt nie znika z mojego radaru. Zostaję dostępny na pytania, drobne poprawki i obserwuję, czy wszystko działa tak, jak zakładaliśmy.",
    badge: "+ wsparcie",
  },
];
---

<section class="block reveal" id="how">
  <div class="container">
    <SectionHead label="Jak pracuję">Kilka zasad, które <em>działają</em>.</SectionHead>

    <div class="how-timeline">
      <header class="how-head">
        <span>proces.mdc</span>
        <span class="dot-row" aria-hidden="true"><i></i><i></i><i></i></span>
      </header>

      <div class="how-track">
        {
          steps.map((step, idx) => (
            <article class="step" data-side={idx % 2 === 0 ? "left" : "right"}>
              <div class="step-card">
                <header class="step-head">
                  <span class="step-num">{step.num}</span>
                  <h4>{step.title}</h4>
                  <span class="step-badge">{step.badge}</span>
                </header>
                <p>{step.description}</p>
              </div>
            </article>
          ))
        }
      </div>

      <footer class="how-foot">
        <span>status</span>
        <span class="how-foot-meta">{steps.length} kroków</span>
      </footer>
    </div>
  </div>
</section>

<style>
  .how-timeline {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: light-dark(var(--card), var(--paper-2));
    border: 1px solid var(--line);
  }

  .how-head,
  .how-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 28px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .how-head {
    border-bottom: 1px solid var(--line-2);
  }

  .how-foot {
    border-top: 1px solid var(--line-2);
  }

  .how-foot-meta {
    font-weight: 500;
    color: var(--blue);
  }

  .dot-row {
    display: inline-flex;
    gap: 4px;
  }

  .dot-row i {
    display: inline-block;
    width: 8px;
    height: 8px;
    background: var(--line);
    border-radius: 50%;
  }

  /* ===== Timeline track ===== */

  .how-track {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 28px;
    padding: 36px 28px;
  }

  .how-track::before {
    position: absolute;
    top: 36px;
    bottom: 36px;
    left: 50%;
    content: "";
    border-left: 1.5px dashed var(--line);
    transform: translateX(-50%);
  }

  .step {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
  }

  /* Generic .step-card rules first to keep specificity ascending. */
  .step-card {
    position: relative;
    padding: 18px 22px;
    background: var(--paper);
    border: 1px solid var(--line-2);
    transition:
      transform 0.2s ease,
      background 0.2s ease,
      border-color 0.2s ease;
  }

  /* Dot anchored to the centre line, vertically centred against the card. */
  .step-card::before {
    position: absolute;
    top: 50%;
    width: 12px;
    height: 12px;
    margin-top: -6px;
    content: "";
    background: var(--paper);
    border: 2px solid var(--blue);
    border-radius: 50%;
    transition:
      background 0.2s ease,
      box-shadow 0.2s ease;
  }

  .step-card:hover {
    background: var(--blue-wash);
    border-color: var(--blue);
    transform: translateY(-1px);
  }

  .step-card:hover::before {
    background: var(--blue);
    box-shadow: 0 0 0 5px var(--blue-wash);
  }

  /* Side-specific overrides come after the generic rules. */
  .step[data-side="left"] .step-card {
    grid-column: 1;
  }

  .step[data-side="right"] .step-card {
    grid-column: 2;
  }

  .step[data-side="left"] .step-card::before {
    right: -34px;
  }

  .step[data-side="right"] .step-card::before {
    left: -34px;
  }

  .step-head {
    display: flex;
    gap: 12px;
    align-items: baseline;
    margin-bottom: 8px;
  }

  .step-num {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--blue);
    letter-spacing: 0.1em;
  }

  .step-card h4 {
    flex: 1;
    margin: 0;
    font-family: var(--display);
    font-size: 16px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  .step-badge {
    padding: 3px 8px;
    font-family: var(--mono);
    font-size: 10px;
    color: var(--blue);
    letter-spacing: 0.05em;
    white-space: nowrap;
    background: var(--blue-wash);
  }

  .step-card p {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--muted);
  }

  @media (max-width: 880px) {
    .how-track {
      padding: 28px 20px 28px 44px;
    }

    .how-track::before {
      top: 28px;
      bottom: 28px;
      left: 16px;
      transform: none;
    }

    .step {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .step[data-side="left"] .step-card,
    .step[data-side="right"] .step-card {
      grid-column: 1;
    }

    .step[data-side="left"] .step-card::before,
    .step[data-side="right"] .step-card::before {
      right: auto;
      left: -34px;
    }
  }

  /* prefers-reduced-motion handled globally in global.css (universal selector
   * sets transition-duration: 0.01ms !important). No per-component override
   * needed. */
</style>

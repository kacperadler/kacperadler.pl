---
import SectionHead from "@/components/ui/section-head.astro";

interface FlowStep {
  badge: string;
  description: string;
  heading: string;
  num: string;
  title: string;
}

const steps: readonly FlowStep[] = [
  {
    num: "01",
    title: "Rozmowa",
    badge: "~ 30 min",
    heading: "Zaczynamy od rozmowy.",
    description:
      "Krótkie spotkanie lub wymiana maili — opowiadasz, co chcesz zbudować i po co. Ja zadaję pytania, żeby zrozumieć Twój biznes, użytkowników i priorytety.",
  },
  {
    num: "02",
    title: "Plan & wycena",
    badge: "2–3 dni",
    heading: "Plan i realna wycena.",
    description:
      "Po rozmowie dostajesz od mnie krótki dokument: co robimy, w jakiej kolejności, ile to zajmie i ile kosztuje. Bez ukrytych kosztów, bez niespodzianek w trakcie.",
  },
  {
    num: "03",
    title: "Budowa",
    badge: "sprinty",
    heading: "Budujemy krok po kroku.",
    description:
      "Pracuję w małych etapach — co tydzień widzisz postęp na działającej wersji strony, nie na screenach. Łatwiej wtedy reagować, jeśli coś idzie w niedobrą stronę.",
  },
  {
    num: "04",
    title: "Feedback",
    badge: "na bieżąco",
    heading: "Twój feedback idzie do kodu.",
    description:
      "Nie musisz znać się na technologii. Mówisz „to powinno być szybsze”, „tu brakuje jasności”, „zmieńmy kolejność” — ja tłumaczę to na konkretne zmiany i pokazuję efekt.",
  },
  {
    num: "05",
    title: "Wdrożenie",
    badge: "+ wsparcie",
    heading: "Wdrożenie i wsparcie po.",
    description:
      "Po odpaleniu projekt nie znika z mojego radaru. Zostaję dostępny na pytania, drobne poprawki i obserwuję, czy wszystko działa tak, jak zakładaliśmy.",
  },
];
---

<section class="block reveal" id="how">
  <div class="container">
    <SectionHead label="Jak pracuję">Kilka zasad, które <em>działają</em>.</SectionHead>

    <div class="how">
      <aside class="how-visual" aria-hidden="true" data-flow-visual>
        <div class="how-visual-head">
          <span>proces.mdc</span>
          <span class="dot-row"><i></i><i></i><i></i></span>
        </div>

        <div class="how-visual-body">
          {
            steps.map((step, idx) => (
              <>
                <div class="flow-node" data-step={idx}>
                  <div class="idx">{step.num}</div>
                  <div class="title">{step.title}</div>
                  <div class="badge">{step.badge}</div>
                </div>
                {idx < steps.length - 1 && <div class="flow-connector" />}
              </>
            ))
          }
        </div>

        <div class="how-visual-foot">
          <span>status</span>
          <span class="progress" data-flow-progress
            >krok 01 / {steps.length.toString().padStart(2, "0")}</span
          >
        </div>
      </aside>

      <div class="how-list">
        {
          steps.map((step, idx) => (
            <div class="how-item" data-step={idx}>
              <div class="n">{step.num}</div>
              <div>
                <h4>{step.heading}</h4>
                <p>{step.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .how {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 56px;
    align-items: start;
  }

  .how-visual {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    height: 499px;
    padding: 28px;
    overflow: hidden;
    background: light-dark(var(--card), var(--paper-2));
    border: 1px solid var(--line);
  }

  .how-visual-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 14px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-bottom: 1px solid var(--line-2);
  }

  .dot-row {
    display: inline-flex;
    gap: 4px;
  }

  .dot-row i {
    display: inline-block;
    width: 8px;
    height: 8px;
    background: var(--line);
    border-radius: 50%;
  }

  .how-visual-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 10px;
    justify-content: center;
    min-height: 0;
    padding: 18px 0;
  }

  .flow-node {
    display: grid;
    grid-template-columns: 36px 1fr auto;
    gap: 14px;
    align-items: center;
    padding: 12px 14px;
    background: var(--paper);
    border: 1px solid var(--line-2);
    opacity: 0.5;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .flow-node.active {
    background: var(--blue-wash);
    border-color: var(--blue);
    opacity: 1;
    transform: translateX(4px);
  }

  .idx {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--ink-2);
    background: var(--card);
    border: 1px solid var(--line);
  }

  .flow-node.active .idx {
    color: light-dark(var(--paper), #0f1116);
    background: var(--blue);
    border-color: var(--blue);
  }

  .flow-node .title {
    font-family: var(--display);
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  .flow-node .badge {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.05em;
  }

  .flow-node.active .badge {
    font-weight: 500;
    color: var(--blue);
  }

  .flow-connector {
    position: relative;
    height: 8px;
    margin-left: 28px;
    border-left: 1.5px dashed var(--line);
  }

  .how-visual-foot {
    display: flex;
    justify-content: space-between;
    padding-top: 14px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    border-top: 1px solid var(--line-2);
  }

  .progress {
    font-family: var(--mono);
    font-weight: 500;
    color: var(--blue);
  }

  .how-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .how-item {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 18px;
    align-items: baseline;
    padding: 20px 0;
    border-bottom: 1px solid var(--line-2);
  }

  .how-item:last-child {
    border-bottom: none;
  }

  .n {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--blue);
    letter-spacing: 0.1em;
  }

  h4 {
    margin: 0 0 4px;
    font-family: var(--display);
    font-size: 17px;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  p {
    margin: 0;
    font-size: 15px;
    color: var(--muted);
  }

  @media (max-width: 880px) {
    .how {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .how-visual {
      position: static;
      height: auto;
      aspect-ratio: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .flow-node {
      transition: none;
    }
  }
</style>

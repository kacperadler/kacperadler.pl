---
import { Icon } from "astro-icon/components";
import Card from "@/components/ui/card.astro";
import { processSteps as steps } from "@/data/process";
---

<section class="how" id="how">
  <div class="container">
    <header class="section-head">
      <p class="eyebrow eyebrow-section">Proces</p>
      <h2>
        Od <em>rozmowy</em> do <em>produktu</em>.
      </h2>
      <p class="section-lede">
        Biorąc pod uwagę Twoje potrzeby, skupiam się na znalezieniu najlepszego rozwiązania dla
        Ciebie.
      </p>
    </header>

    <ol class="how-steps">
      {
        steps.map((step) => (
          <li class="step-item">
            <div aria-hidden="true" class="step-marker">
              <span class="step-dot">{step.num}</span>
            </div>
            <Card class="step-panel">
              <header class="step-head">
                <Icon aria-hidden="true" class="step-icon" name={step.icon} />
                <h3>{step.title}</h3>
                <span class="step-badge">{step.badge}</span>
              </header>
              <p class="step-desc">{step.description}</p>
            </Card>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  /* How I work - vertical timeline. Each li is a 2-col grid: 56px marker
   * rail with a numbered glass dot + connector line, 1fr panel that uses
   * the standard glass-on-hover treatment. Reads as roadmap. */
  .how {
    margin-top: var(--v2-space-2xl);
  }

  .how-steps {
    display: flex;
    flex-direction: column;
    gap: var(--v2-space-md);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .step-item {
    position: relative;
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: var(--v2-space-md);
    align-items: stretch;
  }

  /* Marker column - holds the numbered dot + connector line down to the
   * next dot. Last item's connector is hidden. The line is a top→bottom
   * blue gradient, suggesting flow forward. */
  .step-marker {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .step-marker::before {
    position: absolute;
    top: 48px;
    bottom: calc(-1 * var(--v2-space-md));
    left: 50%;
    width: 2px;
    content: "";
    background: linear-gradient(
      color-mix(in srgb, var(--blue) 50%, transparent),
      color-mix(in srgb, var(--blue) 20%, transparent)
    );
    transform: translateX(-50%);
  }

  .step-item:last-child .step-marker::before {
    display: none;
  }

  /* Numbered glass dot - lights up via :has() when its sibling panel is
   * hovered. Backdrop-blur lets the ribbons show through subtly. */
  .step-dot {
    position: relative;
    z-index: 1;
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    font-family: var(--display);
    font-size: 15px;
    font-weight: 500;
    color: var(--blue);
    letter-spacing: -0.01em;
    background: color-mix(in srgb, var(--v2-panel) 70%, transparent);
    border: 1px solid color-mix(in srgb, var(--blue) 35%, var(--v2-line));
    border-radius: var(--v2-radius-full);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    transition:
      background 0.3s ease,
      border-color 0.3s ease;
  }

  .step-item:has(.step-panel:hover) .step-dot {
    background: color-mix(in srgb, var(--blue) 18%, var(--v2-panel));
    border-color: color-mix(in srgb, var(--blue) 80%, transparent);
  }

  /* Panel base + glass-on-hover come from the <Card> component. */

  .step-head {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    margin-bottom: 12px;
  }

  .step-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    color: var(--blue);
  }

  .step-panel h3 {
    flex: 1;
    margin: 0;
    font-family: var(--display);
    font-size: 20px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  .step-badge {
    padding: 4px 10px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
    background: transparent;
    border: 1px solid var(--v2-line);
    border-radius: var(--v2-radius-xs);
    transition:
      background 0.3s ease,
      border-color 0.3s ease,
      color 0.3s ease;
  }

  /* On panel hover badge swaps to "active" filled blue-wash - same vocab
   * as .status-pill and the current-role badge. */
  .step-panel:hover .step-badge {
    color: var(--blue);
    background: var(--blue-wash);
    border-color: transparent;
  }

  .step-desc {
    max-width: 70ch;
    margin: 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink-2);
  }

  @media (max-width: 880px) {
    .how {
      margin-top: var(--v2-space-xl);
    }

    .step-panel {
      padding: var(--v2-space-md);
    }

    /* Compact rail on mobile - 40px col / 36px dot keeps the timeline
     * affordance without eating too much horizontal space. */
    .step-item {
      grid-template-columns: 40px 1fr;
      gap: 12px;
    }

    .step-dot {
      width: 36px;
      height: 36px;
      font-size: 13px;
    }

    .step-marker::before {
      top: 36px;
      bottom: -12px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .step-dot,
    .step-badge {
      transition: none;
    }
  }
</style>

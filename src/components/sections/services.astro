---
import { getCollection } from "astro:content";
import Card from "@/components/ui/card.astro";

const services = (await getCollection("services")).sort((a, b) => a.data.order - b.data.order);
---

<section class="services" id="services">
  <div class="container">
    <header class="section-head">
      <p class="eyebrow eyebrow-section">Usługi</p>
      <h2>
        Obszary w&nbsp;których <em>działam</em>.
      </h2>
      <p class="section-lede">
        Moje doświadczenie pozwala mi na pracę w wielu technologiach<br />i projektach.
      </p>
    </header>

    <div class="services-grid">
      {
        services.map((service, idx) => (
          <Card class="service-panel">
            <header class="service-head">
              <h3>{service.data.title}</h3>
              <span aria-hidden="true" class="service-num">
                {String(idx + 1).padStart(2, "0")}
              </span>
            </header>
            <p>{service.data.description}</p>
            <ul class="service-tags">
              {service.data.tags.map((tag) => (
                <li class="chip">{tag}</li>
              ))}
            </ul>
          </Card>
        ))
      }
    </div>
  </div>
</section>

<style>
  .services {
    margin-top: var(--v2-space-2xl);
  }

  /* 2-col grid on desktop, single column from 880px down. Gap shows the
   * dot grid through, which is the whole point. */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--v2-space-md);
  }

  /* Odd count -> last card sits alone in the trailing row. Span both
   * columns, constrain width to a single column, and justify-self center
   * so it lines up between the two columns above instead of hugging the
   * left edge. :last-child:nth-child(odd) auto-disables once a 6th card
   * is added. */
  @media (min-width: 881px) {
    .services-grid .service-panel:last-child:nth-child(odd) {
      grid-column: 1 / -1;
      width: calc((100% - var(--v2-space-md)) / 2);
      justify-self: center;
    }
  }

  /* Panel base + glass-on-hover come from the <Card> component; the
   * .service-panel class only carries section-specific bits (title row,
   * ghost number, tags). */

  /* Title row - h3 on the left, ghost number on the right at same baseline. */
  .service-head {
    display: flex;
    gap: 16px;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .service-panel h3 {
    margin: 0;
    font-family: var(--display);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  /* Ghost number - large display digit anchored to the right of the title
   * row, faded so it reads as background label rather than competing. */
  .service-num {
    flex-shrink: 0;
    font-family: var(--display);
    font-size: 36px;
    font-weight: 400;
    line-height: 1;
    color: var(--muted);
    letter-spacing: -0.02em;
    opacity: 0.3;
    transition: opacity 0.3s ease;
  }

  .service-panel:hover .service-num {
    opacity: 0.6;
  }

  .service-panel p {
    margin: 0 0 20px;
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-2);
  }

  /* Tag chips - mono badges, transparent bg with a thin border so they
   * read as separate elements on the panel without fighting the border. */
  .service-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 0;
    margin: auto 0 0;
    list-style: none;
  }

  .chip {
    padding: 4px 10px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-2);
    background: transparent;
    border: 1px solid var(--v2-line);
    border-radius: var(--v2-radius-xs);
  }

  @media (max-width: 880px) {
    .services {
      margin-top: var(--v2-space-xl);
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .service-panel {
      padding: var(--v2-space-md);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .service-num {
      transition: none;
    }
  }
</style>

---
import { getCollection } from "astro:content";
import SectionHead from "@/components/ui/section-head.astro";
import { roundedYearsLabel, totalYearsFloor, yearsUnit } from "@/lib/dates";

const all = (await getCollection("experience")).sort((a, b) => a.data.order - b.data.order);
const items = all.slice(0, 4);

// Section title shows total years from earliest startDate across the
// FULL collection (not the displayed slice) - total tenure is the
// honest signal.
const earliestStart = all
  .map((i) => i.data.startDate)
  .sort()
  .at(0);
const totalYears = earliestStart ? totalYearsFloor(earliestStart) : 0;
---

<section class="block reveal" id="experience">
  <div class="container">
    <SectionHead
      label="Doświadczenie"
      lede="Cztery firmy, jedna pasja: frontend dla zespołów produktowych."
    >
      {`~ ${totalYears} ${yearsUnit(totalYears)} w `}<em>branży frontendowej</em>.
    </SectionHead>

    <div class="timeline">
      {
        items.map((item) => (
          <div class:list={["t-item", { now: item.data.current }]}>
            <div class="t-head">
              <h3>{item.data.company}</h3>
              {item.data.current ? (
                <span class="meta meta-now">teraz</span>
              ) : (
                <span class="meta">
                  {roundedYearsLabel(item.data.startDate, item.data.endDate)}
                </span>
              )}
            </div>
            <div class="t-role">{item.data.role}</div>
            <p class="t-desc">
              {item.data.location && <strong class="t-location">{item.data.location}.</strong>}
              {item.data.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .timeline {
    position: relative;
    padding-left: 36px;
  }

  .timeline::before {
    position: absolute;
    top: 8px;
    bottom: 8px;
    left: 9px;
    content: "";
    border-left: 1.5px dashed var(--line);
  }

  .t-item {
    position: relative;
    padding: 14px 0 22px;
  }

  .t-item::before {
    position: absolute;
    top: 22px;
    left: -32px;
    width: 10px;
    height: 10px;
    content: "";
    background: var(--paper);
    border: 2px solid var(--blue);
    border-radius: 50%;
    transition: background 0.2s ease;
  }

  .t-item.now::before {
    background: var(--blue);
    box-shadow: 0 0 0 5px var(--blue-wash);
  }

  .t-head {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: baseline;
    justify-content: space-between;
  }

  .t-head h3 {
    margin: 0;
    font-family: var(--display);
    font-size: 19px;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .t-head .meta {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.02em;
  }

  .t-head .meta-now {
    color: var(--blue);
  }

  .t-role {
    margin-top: 2px;
    font-size: 14px;
    font-weight: 500;
    color: var(--blue);
  }

  .t-desc {
    max-width: 68ch;
    margin: 10px 0 0;
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-2);
  }

  .t-location {
    margin-right: 4px;
    font-weight: 500;
    color: var(--ink);
  }
</style>

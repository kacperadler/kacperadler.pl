---
import { getCollection } from "astro:content";
import type { ImageMetadata } from "astro";
import apptensionLogo from "@/assets/experience/apptension.svg";
import energiadirectLogo from "@/assets/experience/energiadirect.svg";
import helpfindLogo from "@/assets/experience/helpfind.svg";
import paylooLogo from "@/assets/experience/payloo.jpg";
import pwcLogo from "@/assets/experience/pwc.svg";
import rexLogo from "@/assets/experience/rex.svg";
import Card from "@/components/ui/card.astro";

/* Logo wall ("Współpracowałem z"). logoBySlug maps content collection ids
 * (filename without .json) to imported image assets. Entries without a
 * matching logo are filtered out so we never render empty cards. */
const logoBySlug: Record<string, ImageMetadata> = {
  apptension: apptensionLogo,
  energiadirect: energiadirectLogo,
  helpfind: helpfindLogo,
  payloo: paylooLogo,
  pwc: pwcLogo,
  rex: rexLogo,
};

const experience = (await getCollection("experience"))
  .filter((item) => Boolean(logoBySlug[item.id]))
  .sort((a, b) => a.data.order - b.data.order);
---

<section class="experience" id="experience">
  <div class="container">
    <header class="section-head">
      <p class="eyebrow eyebrow-section">Współprace</p>
      <h2>
        Realizacje i&nbsp;<em>współprace</em>.
      </h2>
      <p class="section-lede">
        Tworzyłem projekty i współpracowałem z firmami z różnych branż - od korporacji po
        side-projekty.
      </p>
    </header>

    <ul class="exp-list">
      {
        experience.map((item) => {
          // Filter above guarantees logo exists; assert for TS.
          const logo = logoBySlug[item.id] as ImageMetadata;
          const startYear = item.data.startDate.slice(0, 4);
          const endYear = item.data.endDate?.slice(0, 4);
          // Badge label: current → "teraz"; badge override → that label; else
          // year range. Filled (.exp-meta-now styling) when current OR badge
          // override is set, otherwise the muted outline year range.
          let metaLabel: string;
          let metaFilled: boolean;
          if (item.data.current) {
            metaLabel = "teraz";
            metaFilled = true;
          } else if (item.data.badge) {
            metaLabel = item.data.badge;
            metaFilled = true;
          } else {
            metaLabel = `${startYear}–${endYear}`;
            metaFilled = false;
          }
          return (
            <Card class="exp-panel" tag="li">
              <header class="exp-head">
                <div class="exp-logo-wrap">
                  <img
                    alt={item.data.company}
                    class="exp-logo"
                    height={logo.height}
                    src={logo.src}
                    width={logo.width}
                  />
                </div>
                <span class:list={["exp-meta", { "exp-meta-now": metaFilled }]}>{metaLabel}</span>
              </header>
              <h3>{item.data.company}</h3>
              <div class="exp-role">{item.data.role}</div>
              <p class="exp-desc">{item.data.description}</p>
            </Card>
          );
        })
      }
    </ul>
  </div>
</section>

<style>
  /* Experience - "Współpracowałem z" logo wall. Cards reuse the standard
   * glass-on-hover + spotlight treatment. Logo is grayscale + dimmed idle,
   * snaps to full color + opacity 1 on hover so the brand identifies on
   * engagement. Mix of SVG and raster (jpeg/png) sources both respond to
   * the filter. */
  .experience {
    margin-top: var(--v2-space-2xl);
  }

  .exp-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--v2-space-md);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  /* Panel base + glass-on-hover come from the <Card> component. */

  .exp-head {
    display: flex;
    gap: 12px;
    align-items: center;
    justify-content: space-between;
    min-height: 40px;
    margin-bottom: 16px;
  }

  /* Logo wrap is a flex container with fixed height - the img keeps its
   * aspect ratio via max-height + width:auto. Grayscale + 0.6 opacity
   * idle gives the unified "logo wall" feel; hover snaps to full color. */
  .exp-logo-wrap {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    height: 32px;
  }

  .exp-logo {
    width: auto;
    max-width: 140px;
    max-height: 32px;
    opacity: 0.6;
    filter: grayscale(100%);
    transition:
      filter 0.3s ease,
      opacity 0.3s ease;
  }

  .exp-panel:hover .exp-logo {
    opacity: 1;
    filter: grayscale(0%);
  }

  .exp-meta {
    padding: 4px 10px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
    background: transparent;
    border: 1px solid var(--v2-line);
    border-radius: var(--v2-radius-xs);
  }

  /* Filled badge - "teraz" for current role, or whatever the entry's
   * `badge` field overrides to (e.g., "Zlecenie"). Same blue-wash vocab
   * as the hero status-pill. */
  .exp-meta-now {
    color: var(--blue);
    background: var(--blue-wash);
    border-color: transparent;
  }

  .exp-panel h3 {
    margin: 0 0 4px;
    font-family: var(--display);
    font-size: 18px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  .exp-role {
    margin-bottom: 12px;
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--blue);
    letter-spacing: 0.02em;
  }

  .exp-desc {
    flex: 1;
    margin: 0;
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-2);
  }

  @media (max-width: 880px) {
    .experience {
      margin-top: var(--v2-space-xl);
    }

    .exp-panel {
      padding: var(--v2-space-md);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .exp-logo {
      transition: none;
    }
  }
</style>

---
import Button from "@/components/ui/button.astro";
import Chip from "@/components/ui/chip.astro";
import { siteConfig } from "@/data/site-config";

interface HeroChip {
  highlighted?: boolean;
  label: string;
}

const chips: readonly HeroChip[] = [
  { label: "React", highlighted: true },
  { label: "React Native", highlighted: true },
  { label: "TypeScript", highlighted: true },
  { label: "Next.js" },
  { label: "Tailwind" },
  { label: "React Query" },
  { label: "Zustand" },
  { label: "Angular" },
  { label: "MCP" },
  { label: "LLM" },
];
---

<section class="hero reveal">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-text">
        <div class="eyebrow">
          <span class="dot" aria-hidden="true"></span>
          {siteConfig.role} · Polska
        </div>

        <h1>
          Buduję <em>interfejsy</em> dla produktów,<br />
          z których ludzie korzystają codziennie.
        </h1>

        <p class="hero-sub">
          Aplikacje webowe, narzędzia B2B i landing pages - od architektury po deploy. Pracuję w
          sprintach, async, z zespołami produktowymi w PL/EU.
        </p>

        <div class="hero-ctas">
          <Button variant="primary" href="#contact" icon="lucide:arrow-right">
            Porozmawiajmy
          </Button>
          <Button variant="ghost" href="#how">Jak pracuję</Button>
        </div>

        <div class="hero-stack" aria-label="Technologie">
          {chips.map((c) => <Chip highlighted={c.highlighted}>{c.label}</Chip>)}
        </div>
      </div>

      <div class="hero-mock">
        <div class="phone" aria-hidden="true">
          <div class="phone-notch"></div>
          <div class="phone-screen">
            <div class="screen-status">
              <span>9:41</span>
              <span class="status-dots">•••</span>
            </div>

            <div class="welcome">
              <div class="welcome-mark">k</div>
              <div class="welcome-greet">Cześć!</div>
              <p class="welcome-text">Fajnie że wpadłeś.<br />W czym mogę Ci dziś pomóc?</p>
            </div>

            <a class="welcome-cta" href="#contact" tabindex="-1">
              Formularz kontaktowy
              <span class="welcome-arrow">→</span>
            </a>
          </div>
          <div class="phone-home"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 80px 0 60px;
    overflow: hidden;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(0, 1fr);
    gap: 56px;
    align-items: center;
  }

  .eyebrow {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 20px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .dot {
    width: 8px;
    height: 8px;
    background: var(--blue);
    border-radius: 50%;
    box-shadow: 0 0 0 4px var(--blue-wash);
    animation: pulse 2.4s ease-in-out infinite;
  }

  @keyframes pulse {
    50% {
      box-shadow: 0 0 0 8px transparent;
    }
  }

  h1 {
    margin: 0 0 22px;
    font-family: var(--display);
    font-size: 56px;
    font-weight: 500;
    line-height: 1.04;
    letter-spacing: -0.035em;
    text-wrap: balance;
  }

  h1 em {
    font-style: normal;
    color: var(--blue);
  }

  .hero-sub {
    max-width: 52ch;
    margin: 0 0 28px;
    font-size: 18px;
    line-height: 1.55;
    color: var(--ink-2);
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  .hero-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 32px;
  }

  .hero-mock {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .phone {
    position: relative;
    width: 240px;
    aspect-ratio: 9 / 19;
    padding: 8px;
    background: #14171c;
    border-radius: 36px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 22px 50px -28px light-dark(rgba(20, 20, 22, 0.35), rgba(0, 0, 0, 0.65));
  }

  .phone-notch {
    position: absolute;
    top: 18px;
    left: 50%;
    z-index: 2;
    width: 70px;
    height: 18px;
    background: #14171c;
    border-radius: 99px;
    transform: translateX(-50%);
  }

  .phone-screen {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
    padding: 28px 16px 24px;
    overflow: hidden;
    background: light-dark(#fafaf6, #0c0d0f);
    border-radius: 28px;
  }

  .screen-status {
    display: flex;
    justify-content: space-between;
    margin-bottom: 18px;
    font-family: var(--mono);
    font-size: 9px;
    color: light-dark(#141416, #f5f0e6);
  }

  .status-dots {
    letter-spacing: 1px;
  }

  .welcome {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 12px;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .welcome-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    margin-bottom: 4px;
    font-family: var(--mono);
    font-size: 22px;
    font-weight: 600;
    color: light-dark(#fafaf6, #0c0d0f);
    background: var(--blue);
    border-radius: 14px;
    box-shadow: 0 8px 20px -10px var(--blue);
  }

  .welcome-greet {
    font-family: var(--display);
    font-size: 28px;
    font-weight: 500;
    color: light-dark(#141416, #f5f0e6);
    letter-spacing: -0.03em;
  }

  .welcome-text {
    max-width: 22ch;
    margin: 0;
    font-size: 12px;
    line-height: 1.5;
    color: light-dark(#6c6a64, rgba(255, 255, 255, 0.6));
  }

  .welcome-cta {
    display: inline-flex;
    gap: 6px;
    align-items: center;
    align-self: center;
    padding: 7px 12px;
    margin-bottom: 18px;
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 500;
    color: light-dark(#fafaf6, #0c0d0f);
    background: var(--blue);
    border-radius: 99px;
  }

  .welcome-arrow {
    font-size: 11px;
  }

  .phone-home {
    position: absolute;
    bottom: 14px;
    left: 50%;
    width: 90px;
    height: 4px;
    background: light-dark(rgba(20, 20, 22, 0.35), rgba(255, 255, 255, 0.4));
    border-radius: 99px;
    transform: translateX(-50%);
  }

  @media (max-width: 880px) {
    .hero {
      padding: 48px 0 32px;
    }

    .hero-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .hero-mock {
      grid-row: 1;
    }

    h1 {
      font-size: 40px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dot {
      animation: none;
    }
  }
</style>

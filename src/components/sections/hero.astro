---
import { Image } from "astro:assets";
import meJpg from "@/assets/me.jpg";
import Button from "@/components/ui/button.astro";
import Chip from "@/components/ui/chip.astro";
import { siteConfig } from "@/data/site-config";

interface HeroChip {
  highlighted?: boolean;
  label: string;
}

const chips: readonly HeroChip[] = [
  { label: "React", highlighted: true },
  { label: "React Native", highlighted: true },
  { label: "TypeScript", highlighted: true },
  { label: "Next.js" },
  { label: "Tailwind" },
  { label: "React Query" },
  { label: "Zustand" },
  { label: "Angular" },
  { label: "MCP" },
  { label: "LLM" },
];
---

<section class="hero reveal">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-text">
        <div class="eyebrow">
          <span class="dot" aria-hidden="true"></span>
          {siteConfig.role} · Polska
        </div>

        <h1>
          Buduję <em>interfejsy</em> dla produktów,<br />
          z których ludzie korzystają codziennie.
        </h1>

        <p class="hero-sub">
          Aplikacje webowe, narzędzia B2B i landing pages — od architektury po deploy. Pracuję w
          sprintach, async, z zespołami produktowymi w PL/EU.
        </p>

        <div class="hero-ctas">
          <Button variant="primary" href="#contact" icon="lucide:arrow-right">
            Porozmawiajmy
          </Button>
          <Button variant="ghost" href="#how">Jak pracuję</Button>
        </div>

        <div class="hero-stack" aria-label="Technologie">
          {chips.map((c) => <Chip highlighted={c.highlighted}>{c.label}</Chip>)}
        </div>
      </div>

      <div class="hero-portrait">
        <Image
          src={meJpg}
          alt={siteConfig.name}
          width={520}
          height={450}
          loading="eager"
          fetchpriority="high"
          class="hero-photo"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 80px 0 60px;
    overflow: hidden;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(0, 1fr);
    gap: 56px;
    align-items: center;
  }

  .eyebrow {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 20px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .dot {
    width: 8px;
    height: 8px;
    background: var(--blue);
    border-radius: 50%;
    box-shadow: 0 0 0 4px var(--blue-wash);
    animation: pulse 2.4s ease-in-out infinite;
  }

  @keyframes pulse {
    50% {
      box-shadow: 0 0 0 8px transparent;
    }
  }

  h1 {
    margin: 0 0 22px;
    font-family: var(--display);
    font-size: 56px;
    font-weight: 500;
    line-height: 1.04;
    letter-spacing: -0.035em;
    text-wrap: balance;
  }

  h1 em {
    font-style: normal;
    color: var(--blue);
  }

  .hero-sub {
    max-width: 52ch;
    margin: 0 0 28px;
    font-size: 18px;
    line-height: 1.55;
    color: var(--ink-2);
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  .hero-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 32px;
  }

  .hero-portrait {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-portrait :global(.hero-photo) {
    width: 100%;
    max-width: 480px;
    height: auto;
    object-fit: cover;
    border: 1px solid var(--line);
    box-shadow:
      0 1px 0 var(--line-2),
      0 22px 44px -30px light-dark(rgba(20, 20, 22, 0.18), rgba(0, 0, 0, 0.55));
  }

  @media (max-width: 880px) {
    .hero {
      padding: 48px 0 32px;
    }

    .hero-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .hero-portrait {
      grid-row: 1;
    }

    h1 {
      font-size: 40px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dot {
      animation: none;
    }
  }
</style>

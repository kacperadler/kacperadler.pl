---
import Button from "@/components/ui/button.astro";
import { siteConfig } from "@/data/site-config";
---

<section class="hero" id="top">
  <div class="container hero-grid">
    <div class="hero-text">
      <p class="eyebrow">
        <span class="dot" aria-hidden="true"></span>
        {siteConfig.role} · Polska
      </p>

      <h1>
        Buduję <em>interfejsy</em> dla produktów,<br />
        z których ludzie korzystają codziennie.
      </h1>

      <p class="hero-sub">
        Aplikacje mobilne, webowe, narzędzia B2B i landing pages - od architektury po deploy.
        Pracuję w sprintach, async, z zespołami produktowymi w PL/EU.
      </p>

      <div class="ctas">
        <Button variant="primary" href="#contact" icon="lucide:arrow-right">Porozmawiajmy</Button>
        <Button variant="ghost" href="#how">Zobacz proces</Button>
      </div>
    </div>

    <aside class="hero-status" aria-label="Stan obecny" data-spotlight>
      <span class="status-pill">
        <span class="status-pill-dot" aria-hidden="true"></span>
        Otwarty na nowe współprace
      </span>

      <dl class="status-rows">
        <div class="status-row">
          <dt class="status-label">Stack</dt>
          <dd class="status-value">React · TypeScript · Astro</dd>
        </div>
        <div class="status-row">
          <dt class="status-label">Teraz</dt>
          <dd class="status-value">Frontend dev w&nbsp;ReX</dd>
        </div>
        <div class="status-row">
          <dt class="status-label">Odpowiadam</dt>
          <dd class="status-value">zwykle w&nbsp;24h</dd>
        </div>
      </dl>
    </aside>
  </div>
</section>

<style>
  /* Hero - no outer panel. The headline column floats directly on the dot
   * grid + ribbons; only the status card opts into a glass surface that
   * lets the ribbon motion bleed through it like the header chrome. */
  .hero {
    padding: var(--v2-space-xl) 0;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: var(--v2-space-xl);
    align-items: center;
  }

  .hero-text {
    min-width: 0;
  }

  h1 {
    max-width: 22ch;
    margin: 0 0 24px;
    font-family: var(--display);
    font-size: clamp(36px, 5.5vw, 60px);
    font-weight: 500;
    line-height: 1.04;
    color: var(--ink);
    letter-spacing: -0.035em;
    text-wrap: balance;
  }

  h1 em {
    font-style: normal;
    color: var(--blue);
  }

  .hero-sub {
    max-width: 56ch;
    margin: 0 0 32px;
    font-size: 18px;
    line-height: 1.55;
    color: var(--ink-2);
  }

  .ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  /* Status card - liquid glass, mirroring the header chrome. Always-on
   * glass (translucent panel + blur + lit-edge inset). The spotlight
   * pseudos live in global.css and pickup via data-spotlight. */
  .hero-status {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--v2-space-md);
    padding: var(--v2-space-lg);
    background: color-mix(in srgb, var(--v2-panel) 55%, transparent);
    border: 1px solid color-mix(in srgb, var(--v2-line) 60%, transparent);
    border-radius: var(--v2-radius-md);
    box-shadow: inset 0 1px 0 light-dark(rgba(255, 255, 255, 0.6), rgba(255, 255, 255, 0.05));
    isolation: isolate;
    -webkit-backdrop-filter: saturate(160%) blur(20px);
    backdrop-filter: saturate(160%) blur(20px);
    transition: background 0.3s ease;
  }

  .status-rows {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin: 0;
  }

  .status-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .status-label {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .status-value {
    margin: 0;
    font-size: 15px;
    font-weight: 500;
    line-height: 1.3;
    color: var(--ink);
  }

  @media (max-width: 880px) {
    .hero {
      padding: var(--v2-space-lg) 0;
    }

    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--v2-space-lg);
      align-items: stretch;
    }

    .hero-status {
      padding: var(--v2-space-md);
    }
  }
</style>

---
import { Icon } from "astro-icon/components";

interface Props {
  external?: boolean;
  href: string;
  icon: string;
  label: string;
  value: string;
}

const { icon, label, value, href, external = false } = Astro.props;
const externalAttrs = external ? { target: "_blank", rel: "noopener" } : {};
---

<a class="contact-link" href={href} {...externalAttrs}>
  <Icon name={icon} aria-hidden="true" />
  <span class="label">{label}</span>
  <span class="val">{value}</span>
</a>

<style>
  .contact-link {
    display: inline-flex;
    gap: 14px;
    align-items: center;
    padding: 14px 18px;
    font-size: 15px;
    color: var(--ink);
    background: var(--card);
    border: 1px solid var(--line);
    transition:
      transform 0.12s ease,
      background 0.15s ease,
      border-color 0.15s ease;
  }

  .contact-link:hover {
    border-color: var(--ink);
    transform: translateX(2px);
  }

  .contact-link :global(svg) {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    color: var(--blue);
  }

  .label {
    margin-right: auto;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .val {
    font-weight: 500;
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-link {
      transition: none;
    }
  }
</style>

---
import { Icon } from "astro-icon/components";

interface ProjectType {
  label: string;
  value: string;
}

const projectTypes: readonly ProjectType[] = [
  { value: "webapp", label: "Aplikacja webowa" },
  { value: "landing", label: "Landing page" },
  { value: "mobile", label: "Aplikacja mobilna" },
  { value: "tool", label: "Narzędzie wewn." },
  { value: "other", label: "Inne" },
];
---

<div class="contact-form-wrap" data-contact-wrap data-state="idle">
  <form class="form" data-contact-form novalidate>
    <div class="field" data-field="email">
      <label for="contact-email">Twój email</label>
      <input
        type="email"
        id="contact-email"
        name="email"
        placeholder="twoj@email.pl"
        autocomplete="email"
        required
      />
      <span class="err">Podaj prawidłowy adres email.</span>
    </div>

    <div class="field" data-field="type">
      <label>Typ projektu</label>
      <div class="radios" role="radiogroup" aria-label="Typ projektu">
        {
          projectTypes.map((opt) => (
            <label class="radio">
              <input name="type" type="radio" value={opt.value} />
              <span>{opt.label}</span>
            </label>
          ))
        }
      </div>
      <span class="err">Wybierz typ projektu.</span>
    </div>

    <div class="field" data-field="message">
      <label for="contact-message">Wiadomość</label>
      <textarea
        id="contact-message"
        name="message"
        placeholder="Opisz krótko, o co chodzi - zakres, deadline, jeśli znane. 2–3 zdania wystarczą, żeby zacząć rozmowę."
        required></textarea>
      <span class="err">Dodaj krótki opis projektu.</span>
    </div>

    <!--
      Honeypot - bots fill every field, humans don't see this one. The
      submit handler drops the request if it's non-empty. aria-hidden +
      tabindex=-1 keeps it out of the keyboard tab order and screen
      reader output; the off-screen position keeps it out of view.
    -->
    <div class="hp" aria-hidden="true">
      <label for="hp-website">Strona WWW (zostaw puste)</label>
      <input type="text" id="hp-website" name="website" tabindex="-1" autocomplete="off" />
    </div>

    <div class="form-error" role="alert" data-form-error>
      <Icon name="lucide:triangle-alert" aria-hidden="true" />
      Coś poszło nie tak. Spróbuj ponownie za chwilę albo napisz mailem na
      <a href="mailto:kontakt@kacperadler.pl">kontakt@kacperadler.pl</a>.
    </div>

    <div class="submit-row">
      <button type="submit" class="btn-submit" data-submit data-state="idle">
        <span class="t">Wyślij wiadomość</span>
        <Icon name="lucide:arrow-right" aria-hidden="true" />
      </button>
    </div>
  </form>

  <div class="form-success-card" role="status" aria-live="polite" data-form-success>
    <div class="success-mark" aria-hidden="true">
      <Icon name="lucide:check" />
    </div>
    <h3>Wiadomość wysłana</h3>
    <p>Dzięki! Odezwę się tego samego dnia, najpóźniej w ciągu 24h.</p>
    <button type="button" class="btn-reset" data-form-reset> Wyślij kolejną wiadomość </button>
  </div>
</div>

<style>
  /* The wrapper holds two states side by side - one is hidden via the
   * data-state attribute below. Stretch keeps the card's height aligned
   * with the left contact-info column when align-self: stretch is set
   * by the parent grid. */
  .contact-form-wrap {
    display: flex;
    flex-direction: column;
  }

  .form {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 18px;
    padding: 28px;
    background: var(--card);
    border: 1px solid var(--line);
  }

  /* On success the form node is hidden entirely and the success card
   * takes its place. Errors keep the form visible (so the user doesn't
   * lose what they wrote) and surface a banner above submit-row. */
  .contact-form-wrap[data-state="success"] .form {
    display: none;
  }

  /* Honeypot - taken out of the visual flow without display:none so
   * autofill / focus-stealing bots that ignore display still hit it. */
  .hp {
    position: absolute;
    left: -10000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .field label {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .field input,
  .field textarea {
    padding: 12px 14px;
    font-family: var(--sans);
    font-size: 15px;
    font-weight: 400;
    color: var(--ink);
    resize: vertical;
    outline: none;
    background: var(--paper);
    border: 1px solid var(--line);
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .field textarea {
    min-height: 130px;
    line-height: 1.55;
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--muted);
    opacity: 0.7;
  }

  .field input:focus,
  .field textarea:focus {
    background: var(--paper);
    border-color: var(--blue);
    box-shadow: 0 0 0 3px var(--blue-wash);
  }

  .field[data-invalid] input,
  .field[data-invalid] textarea {
    border-color: #c44545;
  }

  .err {
    display: none;
    font-size: 12px;
    color: #c44545;
  }

  .field[data-invalid] .err {
    display: block;
  }

  .radios {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .radio {
    position: relative;
  }

  .radio input {
    position: absolute;
    pointer-events: none;
    opacity: 0;
  }

  .radio span {
    display: inline-block;
    padding: 8px 14px;
    font-size: 13px;
    color: var(--ink-2);
    cursor: pointer;
    border: 1px solid var(--line);
    transition: all 0.15s ease;
  }

  .radio input:checked + span {
    font-weight: 500;
    color: var(--blue);
    background: var(--blue-wash);
    border-color: var(--blue);
  }

  .radio:hover span {
    border-color: var(--ink);
  }

  /* Keyboard focus on the radio surfaces a clear ring on the wrapper. */
  .radio input:focus-visible + span {
    outline: 2px solid var(--blue);
    outline-offset: 2px;
  }

  .submit-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    justify-content: flex-end;
    margin-top: auto;
  }

  .btn-submit {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    padding: 12px 22px;
    font-size: 14px;
    font-weight: 500;
    color: light-dark(var(--paper), var(--paper-2));
    background: var(--ink);
    transition:
      transform 0.12s ease,
      opacity 0.15s ease;
  }

  .btn-submit:hover {
    transform: translateY(-1px);
  }

  .btn-submit:disabled,
  .btn-submit[data-state="submitting"] {
    cursor: not-allowed;
    opacity: 0.6;
    transform: none;
  }

  .btn-submit :global(svg) {
    width: 14px;
    height: 14px;
  }

  /* Inline server-error banner above submit-row. Hidden by default,
   * revealed when the wrapper enters error-submit state. */
  .form-error {
    display: none;
    gap: 10px;
    align-items: center;
    padding: 12px 14px;
    font-size: 13px;
    line-height: 1.5;
    color: #c44545;
    background: color-mix(in srgb, #c44545 8%, transparent);
    border: 1px solid color-mix(in srgb, #c44545 30%, transparent);
  }

  .contact-form-wrap[data-state="error-submit"] .form-error {
    display: flex;
  }

  .form-error :global(svg) {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
  }

  .form-error a {
    color: inherit;
    text-decoration: underline;
  }

  /* Replaces the form on success. Sized to fill the same vertical
   * space as the form so the contact section's column heights stay
   * aligned. */
  .form-success-card {
    display: none;
    flex: 1;
    flex-direction: column;
    gap: 12px;
    align-items: center;
    justify-content: center;
    padding: 40px 28px;
    text-align: center;
    background: var(--card);
    border: 1px solid var(--line);
  }

  .contact-form-wrap[data-state="success"] .form-success-card {
    display: flex;
  }

  .success-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    color: light-dark(var(--paper), var(--paper-2));
    background: var(--blue);
    border-radius: 50%;
  }

  .success-mark :global(svg) {
    width: 24px;
    height: 24px;
  }

  .form-success-card h3 {
    margin: 4px 0 0;
    font-family: var(--display);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .form-success-card p {
    max-width: 36ch;
    margin: 0 0 12px;
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink-2);
  }

  .btn-reset {
    padding: 10px 18px;
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
    background: transparent;
    border: 1px solid var(--line);
    transition:
      border-color 0.15s ease,
      color 0.15s ease;
  }

  .btn-reset:hover {
    color: var(--blue);
    border-color: var(--blue);
  }

  @media (prefers-reduced-motion: reduce) {
    .field input,
    .field textarea,
    .radio span,
    .btn-submit,
    .btn-reset {
      transition: none;
    }
  }
</style>

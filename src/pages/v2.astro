---
import { getCollection } from "astro:content";
import { siteConfig } from "@/data/site-config";
import V2Layout from "@/layouts/v2-layout.astro";

/* /v2 - redesign track. noindex via V2Layout default, sitemap
 * exclusion lives in astro.config.ts.
 *
 * Faza 1: hero. Faza 2 (this commit): services as 3-panel grid.
 * Section heads stay text-on-bg (the grid is the stage); only
 * content blocks become panels. */

const services = (await getCollection("services")).sort((a, b) => a.data.order - b.data.order);

interface FlowStep {
  badge: string;
  description: string;
  num: string;
  title: string;
}

const steps: readonly FlowStep[] = [
  {
    num: "01",
    title: "Zaczynamy od rozmowy.",
    description:
      "Krótkie spotkanie albo wymiana maili - co Ci wygodniej. Opowiadasz, co chcesz zbudować i po co; ja zadaję pytania, czasem niewygodne.",
    badge: "~ 30 min",
  },
  {
    num: "02",
    title: "Plan i realna wycena.",
    description:
      "Po rozmowie dostajesz od mnie krótki dokument: co robimy, w jakiej kolejności, ile to zajmie i ile kosztuje. Bez ukrytych kosztów, bez niespodzianek w trakcie.",
    badge: "2–3 dni",
  },
  {
    num: "03",
    title: "Budujemy krok po kroku.",
    description:
      "Pracuję małymi etapami - co tydzień widzisz coś, co działa, nie obrazek. Gdy coś idzie nie tak, łatwiej to zauważyć i poprawić.",
    badge: "podział na etapy",
  },
  {
    num: "04",
    title: "Twój feedback idzie do kodu.",
    description:
      "Nie musisz znać się na technologii. Mówisz „to powinno być szybsze”, „tu brakuje jasności”, „zmieńmy kolejność” - ja tłumaczę to na konkretne zmiany i pokazuję efekt.",
    badge: "na bieżąco",
  },
  {
    num: "05",
    title: "Wdrożenie i bieżący nadzór.",
    description:
      "Po wdrożeniu zostaje monitoring. Łapię błędy zanim staną się problemem, mierzę performance, przygotowuję poprawki. Twój produkt nie jest sam.",
    badge: "+ nadzór",
  },
];
---

<V2Layout title="v2 redesign">
  <main id="top" class="v2-main">
    <div class="v2-container">
      <section class="hero-panel">
        <p class="eyebrow">
          <span class="dot" aria-hidden="true"></span>
          {siteConfig.role} · Polska
        </p>

        <h1>
          Buduję <em>interfejsy</em> dla produktów,<br />
          z których ludzie korzystają codziennie.
        </h1>

        <p class="hero-sub">
          Aplikacje webowe, narzędzia B2B i landing pages - od architektury po deploy. Pracuję w
          sprintach, async, z zespołami produktowymi w PL/EU.
        </p>

        <div class="ctas">
          <a class="btn-primary" href="#contact">
            Porozmawiajmy
            <span aria-hidden="true">→</span>
          </a>
          <a class="btn-ghost" href="#how">Jak pracuję</a>
        </div>
      </section>

      <section class="services-block" id="services">
        <header class="section-head">
          <p class="eyebrow eyebrow-section">Usługi</p>
          <h2>
            Trzy obszary, w&nbsp;których <em>działam</em>.
          </h2>
          <p class="section-lede">
            React i TypeScript jako fundament - reszta dobiera się pod konkretny projekt.
          </p>
        </header>

        <div class="services-grid">
          {
            services.map((service, idx) => (
              <article class="service-panel">
                <div class="service-num">{String(idx + 1).padStart(2, "0")}</div>
                <h3>{service.data.title}</h3>
                <p>{service.data.description}</p>
                <ul class="service-tags">
                  {service.data.tags.map((tag) => (
                    <li class="chip">{tag}</li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </section>

      <section class="how-block" id="how">
        <header class="section-head">
          <p class="eyebrow eyebrow-section">Proces</p>
          <h2>
            Od <em>rozmowy</em> do <em>kodu</em>.
          </h2>
          <p class="section-lede">
            Prosty flow, bez ceremonii. Pięć kroków, dużo rozmowy, miejsce na Twój feedback.
          </p>
        </header>

        <ol class="how-steps">
          {
            steps.map((step) => (
              <li class="step-panel">
                <header class="step-head">
                  <span class="step-num">{step.num}</span>
                  <h3>{step.title}</h3>
                  <span class="step-badge">{step.badge}</span>
                </header>
                <p class="step-desc">{step.description}</p>
              </li>
            ))
          }
        </ol>
      </section>
    </div>
  </main>
</V2Layout>

<style>
  .v2-main {
    padding: 48px 0 96px;
  }

  .v2-container {
    max-width: var(--container);
    padding: 0 var(--v2-space-md);
    margin: 0 auto;
  }

  /* Hero panel - the canonical "panel on grid" demo. Radius reveals
   * the v2-bg dot grid at the corners. */
  .hero-panel {
    padding: var(--v2-space-xl) var(--v2-space-lg);
    background: var(--v2-panel);
    border: 1px solid var(--v2-line);
    border-radius: var(--v2-radius-lg);
  }

  /* Section heads sit on the grid bg directly - they're the stage,
   * not actors. Eyebrow + h2 + lede stack with the same vertical
   * rhythm as v1 to keep brand voice. */
  .services-block {
    margin-top: var(--v2-space-2xl);
  }

  .section-head {
    max-width: 60ch;
    margin: 0 auto var(--v2-space-lg);
    text-align: center;
  }

  .eyebrow-section {
    justify-content: center;
    margin-bottom: 14px;
  }

  .section-head h2 {
    margin: 0 0 12px;
    font-family: var(--display);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 500;
    line-height: 1.1;
    color: var(--ink);
    letter-spacing: -0.025em;
    text-wrap: balance;
  }

  .section-lede {
    max-width: 52ch;
    margin: 0 auto;
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-2);
  }

  /* Three panels on desktop, single column from 880px down. Gap
   * shows the dot grid through, which is the whole point. */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--v2-space-md);
  }

  .service-panel {
    display: flex;
    flex-direction: column;
    padding: var(--v2-space-lg);
    background: var(--v2-panel);
    border: 1px solid var(--v2-line);
    border-radius: var(--v2-radius-md);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease;
  }

  .service-panel:hover {
    border-color: color-mix(in srgb, var(--blue) 35%, var(--v2-line));
    transform: translateY(-2px);
  }

  .service-num {
    margin-bottom: 14px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--blue);
    letter-spacing: 0.12em;
  }

  .service-panel h3 {
    margin: 0 0 10px;
    font-family: var(--display);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  .service-panel p {
    margin: 0 0 20px;
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-2);
  }

  /* Tag chips are small mono badges, transparent bg with a thin
   * border so they read as separate elements on the panel without
   * fighting the panel's own border. */
  .service-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 0;
    margin: auto 0 0;
    list-style: none;
  }

  .chip {
    padding: 4px 10px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-2);
    background: transparent;
    border: 1px solid var(--v2-line);
    border-radius: var(--v2-radius-xs);
  }

  /* How I work — five steps as a vertical column of panels. Same
   * panel surface as services but full-width and stacked, so the
   * grid bg shows through on the gaps. */
  .how-block {
    margin-top: var(--v2-space-2xl);
  }

  .how-steps {
    display: flex;
    flex-direction: column;
    gap: var(--v2-space-md);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .step-panel {
    padding: var(--v2-space-lg);
    background: var(--v2-panel);
    border: 1px solid var(--v2-line);
    border-radius: var(--v2-radius-md);
    transition: border-color 0.2s ease;
  }

  .step-panel:hover {
    border-color: color-mix(in srgb, var(--blue) 30%, var(--v2-line));
  }

  .step-head {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: baseline;
    margin-bottom: 12px;
  }

  .step-num {
    padding: 4px 10px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--blue);
    letter-spacing: 0.1em;
    background: var(--blue-wash);
    border-radius: var(--v2-radius-xs);
  }

  .step-panel h3 {
    flex: 1;
    margin: 0;
    font-family: var(--display);
    font-size: 20px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  .step-badge {
    padding: 4px 10px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
    background: transparent;
    border: 1px solid var(--v2-line);
    border-radius: var(--v2-radius-xs);
  }

  .step-desc {
    max-width: 70ch;
    margin: 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink-2);
  }

  .eyebrow {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    margin: 0 0 24px;
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .dot {
    width: 8px;
    height: 8px;
    background: var(--blue);
    border-radius: var(--v2-radius-full);
    box-shadow: 0 0 0 4px var(--blue-wash);
    animation: pulse 2.4s ease-in-out infinite;
  }

  @keyframes pulse {
    50% {
      box-shadow: 0 0 0 8px transparent;
    }
  }

  h1 {
    max-width: 22ch;
    margin: 0 0 24px;
    font-family: var(--display);
    font-size: clamp(36px, 5.5vw, 60px);
    font-weight: 500;
    line-height: 1.04;
    color: var(--ink);
    letter-spacing: -0.035em;
    text-wrap: balance;
  }

  h1 em,
  .section-head h2 em {
    font-style: normal;
    color: var(--blue);
  }

  .hero-sub {
    max-width: 56ch;
    margin: 0 0 32px;
    font-size: 18px;
    line-height: 1.55;
    color: var(--ink-2);
  }

  .ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  .btn-primary {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    padding: 14px 22px;
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 500;
    color: light-dark(var(--paper), var(--paper-2));
    letter-spacing: 0.04em;
    background: var(--ink);
    border-radius: var(--v2-radius-sm);
    transition:
      transform 0.12s ease,
      box-shadow 0.2s ease;
  }

  .btn-primary:hover {
    box-shadow: 0 8px 24px -12px rgba(20, 20, 22, 0.4);
    transform: translateY(-1px);
  }

  .btn-ghost {
    display: inline-flex;
    gap: 8px;
    align-items: center;
    padding: 14px 18px;
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: 0.04em;
    background: transparent;
    border: 1px solid var(--v2-line);
    border-radius: var(--v2-radius-sm);
    transition: border-color 0.2s ease;
  }

  .btn-ghost:hover {
    border-color: var(--ink);
  }

  @media (max-width: 880px) {
    .v2-main {
      padding: 32px 0 64px;
    }

    .hero-panel {
      padding: var(--v2-space-lg) var(--v2-space-md);
      border-radius: var(--v2-radius-md);
    }

    .services-block,
    .how-block {
      margin-top: var(--v2-space-xl);
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .service-panel,
    .step-panel {
      padding: var(--v2-space-md);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dot {
      animation: none;
    }

    .btn-primary,
    .btn-ghost,
    .service-panel,
    .step-panel {
      transition: none;
    }
  }
</style>

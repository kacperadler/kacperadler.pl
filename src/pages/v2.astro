---
import { getCollection } from "astro:content";
import ContactForm from "@/components/contact/contact-form.astro";
import ContactLink from "@/components/contact/contact-link.astro";
import Button from "@/components/ui/button.astro";
import { siteConfig } from "@/data/site-config";
import V2Layout from "@/layouts/v2-layout.astro";
import { roundedYearsLabel, totalYearsFloor, yearsUnit } from "@/lib/dates";

/* /v2 - redesign track. noindex via V2Layout default, sitemap
 * exclusion lives in astro.config.ts.
 *
 * Faza 1: hero. Faza 2: services + how-i-work + experience + contact.
 * Section heads stay text-on-bg (the grid is the stage); only
 * content blocks become panels. */

const services = (await getCollection("services")).sort((a, b) => a.data.order - b.data.order);

const allExperience = (await getCollection("experience")).sort(
  (a, b) => a.data.order - b.data.order,
);
const experience = allExperience.slice(0, 4);
// Total tenure shown in the section title pulls from the FULL
// collection, not the displayed slice - hidden older roles still
// count toward total years.
const earliestStart = allExperience
  .map((i) => i.data.startDate)
  .sort()
  .at(0);
const totalYears = earliestStart ? totalYearsFloor(earliestStart) : 0;

interface FlowStep {
  badge: string;
  description: string;
  num: string;
  title: string;
}

const steps: readonly FlowStep[] = [
  {
    num: "01",
    title: "Zaczynamy od rozmowy.",
    description:
      "Krótkie spotkanie albo wymiana maili - co Ci wygodniej. Opowiadasz, co chcesz zbudować i po co; ja zadaję pytania, czasem niewygodne.",
    badge: "~ 30 min",
  },
  {
    num: "02",
    title: "Plan i realna wycena.",
    description:
      "Po rozmowie dostajesz od mnie krótki dokument: co robimy, w jakiej kolejności, ile to zajmie i ile kosztuje. Bez ukrytych kosztów, bez niespodzianek w trakcie.",
    badge: "2–3 dni",
  },
  {
    num: "03",
    title: "Budujemy krok po kroku.",
    description:
      "Pracuję małymi etapami - co tydzień widzisz coś, co działa, nie obrazek. Gdy coś idzie nie tak, łatwiej to zauważyć i poprawić.",
    badge: "podział na etapy",
  },
  {
    num: "04",
    title: "Twój feedback idzie do kodu.",
    description:
      "Nie musisz znać się na technologii. Mówisz „to powinno być szybsze”, „tu brakuje jasności”, „zmieńmy kolejność” - ja tłumaczę to na konkretne zmiany i pokazuję efekt.",
    badge: "na bieżąco",
  },
  {
    num: "05",
    title: "Wdrożenie i bieżący nadzór.",
    description:
      "Po wdrożeniu zostaje monitoring. Łapię błędy zanim staną się problemem, mierzę performance, przygotowuję poprawki. Twój produkt nie jest sam.",
    badge: "+ nadzór",
  },
];
---

<V2Layout title="v2 redesign">
  <main id="top" class="v2-main">
    <div class="v2-container">
      <section class="hero-panel">
        <div class="hero-grid">
          <div class="hero-text">
            <p class="eyebrow">
              <span class="dot" aria-hidden="true"></span>
              {siteConfig.role} · Polska
            </p>

            <h1>
              Buduję <em>interfejsy</em> dla produktów,<br />
              z których ludzie korzystają codziennie.
            </h1>

            <p class="hero-sub">
              Aplikacje webowe, narzędzia B2B i landing pages - od architektury po deploy. Pracuję w
              sprintach, async, z zespołami produktowymi w PL/EU.
            </p>

            <div class="ctas">
              <Button variant="primary" href="#contact" icon="lucide:arrow-right">
                Porozmawiajmy
              </Button>
              <Button variant="ghost" href="#how">Zobacz proces</Button>
            </div>
          </div>

          <aside class="hero-status" aria-label="Stan obecny" data-spotlight>
            <span class="status-pill">
              <span class="status-pill-dot" aria-hidden="true"></span>
              Otwarty na nowe współprace
            </span>

            <dl class="status-rows">
              <div class="status-row">
                <dt class="status-label">Stack</dt>
                <dd class="status-value">React · TypeScript · Astro</dd>
              </div>
              <div class="status-row">
                <dt class="status-label">Teraz</dt>
                <dd class="status-value">Frontend dev w&nbsp;ReX</dd>
              </div>
              <div class="status-row">
                <dt class="status-label">Odpowiadam</dt>
                <dd class="status-value">zwykle w&nbsp;24h</dd>
              </div>
            </dl>
          </aside>
        </div>
      </section>

      <section class="services-block" id="services">
        <header class="section-head">
          <p class="eyebrow eyebrow-section">Usługi</p>
          <h2>
            Obszary w&nbsp;których <em>działam</em>.
          </h2>
          <p class="section-lede">
            Moje doświadczenie pozwala mi na pracę w wielu technologiach<br />i projektach.
          </p>
        </header>

        <div class="services-grid">
          {
            services.map((service, idx) => (
              <article class="service-panel" data-spotlight>
                <header class="service-head">
                  <h3>{service.data.title}</h3>
                  <span aria-hidden="true" class="service-num">
                    {String(idx + 1).padStart(2, "0")}
                  </span>
                </header>
                <p>{service.data.description}</p>
                <ul class="service-tags">
                  {service.data.tags.map((tag) => (
                    <li class="chip">{tag}</li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </section>

      <section class="how-block" id="how">
        <header class="section-head">
          <p class="eyebrow eyebrow-section">Proces</p>
          <h2>
            Od <em>rozmowy</em> do <em>kodu</em>.
          </h2>
          <p class="section-lede">
            Biorąc pod uwagę Twój problem, skupiam się na znalezieniu dopasowanego rozwiązania dla
            Ciebie.
          </p>
        </header>

        <ol class="how-steps">
          {
            steps.map((step) => (
              <li class="step-panel">
                <header class="step-head">
                  <span class="step-num">{step.num}</span>
                  <h3>{step.title}</h3>
                  <span class="step-badge">{step.badge}</span>
                </header>
                <p class="step-desc">{step.description}</p>
              </li>
            ))
          }
        </ol>
      </section>

      <section class="exp-block" id="experience">
        <header class="section-head">
          <p class="eyebrow eyebrow-section">Doświadczenie</p>
          <h2>
            {`Ponad ${totalYears} ${yearsUnit(totalYears)} w `}<em>branży</em>.
          </h2>
          <p class="section-lede">Cztery firmy, jedna pasja: frontend dla zespołów produktowych.</p>
        </header>

        <ol class="exp-list">
          {
            experience.map((item) => (
              <li class:list={["exp-panel", { "exp-now": item.data.current }]}>
                <header class="exp-head">
                  <h3>{item.data.company}</h3>
                  {item.data.current ? (
                    <span class="exp-meta exp-meta-now">teraz</span>
                  ) : (
                    <span class="exp-meta">
                      {roundedYearsLabel(item.data.startDate, item.data.endDate)}
                    </span>
                  )}
                </header>
                <div class="exp-role">{item.data.role}</div>
                <p class="exp-desc">
                  {item.data.location && (
                    <strong class="exp-location">{item.data.location}.</strong>
                  )}
                  {item.data.description}
                </p>
              </li>
            ))
          }
        </ol>
      </section>

      <section class="contact-block" id="contact">
        <header class="section-head">
          <p class="eyebrow eyebrow-section">Kontakt</p>
          <h2>
            Opowiedz mi, co <em>budujesz</em>.
          </h2>
          <p class="section-lede">
            Najlepiej mailem albo formularzem. Zwykle wracam tego samego dnia.
          </p>
        </header>

        <div class="contact-grid">
          <aside class="contact-info-panel">
            <div class="reply-badge">
              <span class="reply-dot" aria-hidden="true"></span>
              Odpowiadam zwykle w ciągu 24h
            </div>
            <div class="contact-links">
              <ContactLink
                icon="lucide:mail"
                label="Email"
                value={siteConfig.email}
                href={`mailto:${siteConfig.email}`}
              />
              <ContactLink
                icon="lucide:linkedin"
                label="LinkedIn"
                value="/in/kacperadler"
                href={siteConfig.social.linkedin}
                external
              />
            </div>
            <p class="contact-lead">
              Najchętniej zaczynam od maila - opisz projekt w 2–3 zdaniach, a wrócę z pytaniami albo
              propozycją rozmowy.
            </p>
          </aside>

          <div class="contact-form-host">
            <ContactForm />
          </div>
        </div>
      </section>
    </div>
  </main>
</V2Layout>

<style>
  .v2-main {
    padding: 48px 0 96px;
  }

  .v2-container {
    max-width: var(--container);
    padding: 0 var(--v2-space-md);
    margin: 0 auto;
  }

  /* Hero - intentionally NO outer panel. The headline column floats
   * directly on the dot-grid + ribbons (apptension/firecrawl read);
   * only the status card opts into a surface, and that surface is
   * glass so the ribbon motion bleeds through it like in the header. */
  .hero-panel {
    padding: var(--v2-space-xl) 0;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: var(--v2-space-xl);
    align-items: center;
  }

  .hero-text {
    min-width: 0;
  }

  /* Status card - liquid glass, mirroring the header chrome. Translucent
   * --v2-panel + backdrop-filter blur, lit-edge inset highlight, soft
   * line border. Reads as "atmosphere-floating UI" rather than content
   * panel. Future demo block can live in this slot with the same skin.
   *
   * Two pseudo-elements layered on top render the spotlight effect:
   *   ::before is a soft white wash centered at (--mx, --my) - "the
   *     panel brightens under your cursor".
   *   ::after is a navy radial gradient masked via mask-composite to
   *     a 1px ring - "the border lights up near the cursor".
   *   Both fade in on :hover. --mx / --my are set by spotlight.ts;
   *   default 50%/50% so the resting paint (which is invisible
   *   anyway because opacity:0) doesn't shift on first move.
   *
   * isolation: isolate gives the pseudos their own stacking context
   * so they paint cleanly above the panel bg. */
  .hero-status {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--v2-space-md);
    padding: var(--v2-space-lg);
    background: color-mix(in srgb, var(--v2-panel) 55%, transparent);
    border: 1px solid color-mix(in srgb, var(--v2-line) 60%, transparent);
    border-radius: var(--v2-radius-md);
    box-shadow: inset 0 1px 0 light-dark(rgba(255, 255, 255, 0.6), rgba(255, 255, 255, 0.05));
    isolation: isolate;
    -webkit-backdrop-filter: saturate(160%) blur(20px);
    backdrop-filter: saturate(160%) blur(20px);
  }

  /* Spotlight pattern shared by .hero-status (always glass, spotlight
   * on hover) and .service-panel (opaque idle, glass + spotlight on
   * hover). Same gradient values, same opacity:0→1 transition; only
   * the surface treatment around the pseudos differs per element. */
  .hero-status > *,
  .service-panel > * {
    position: relative;
    z-index: 1;
  }

  .hero-status::before,
  .hero-status::after,
  .service-panel::before,
  .service-panel::after {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: "";
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  /* Surface wash - 220px radius radial-gradient at (--mx, --my). Soft
   * white at 4%, fades to transparent at 55% so the highlight reads
   * as ambient lift, not a flashlight. */
  .hero-status::before,
  .service-panel::before {
    z-index: 0;
    background: radial-gradient(
      220px circle at var(--mx, 50%) var(--my, 50%),
      color-mix(in srgb, white 4%, transparent),
      transparent 55%
    );
  }

  /* Border ring - navy gradient painted across the whole pseudo, then
   * masked via mask-composite: exclude to a 1px ring (whole-box mask
   * MINUS content-box mask = padding strip). Result: only the 1px
   * perimeter is painted, brightest near the cursor. -webkit-mask-
   * composite: xor is the legacy syntax for the same effect. */
  .hero-status::after,
  .service-panel::after {
    z-index: 2;
    padding: 1px;
    background: radial-gradient(
      160px circle at var(--mx, 50%) var(--my, 50%),
      color-mix(in srgb, var(--blue) 50%, transparent),
      transparent 55%
    );
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
  }

  .hero-status:hover::before,
  .hero-status:hover::after,
  .service-panel:hover::before,
  .service-panel:hover::after {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-status::before,
    .hero-status::after,
    .service-panel::before,
    .service-panel::after {
      transition: none;
    }
  }

  /* Static blue-wash pill - intentionally not pulsing. The hero
   * eyebrow already carries the only foreground "live" signal. */
  .status-pill {
    display: inline-flex;
    gap: 8px;
    align-items: center;
    align-self: flex-start;
    padding: 6px 12px;
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--blue);
    background: var(--blue-wash);
    border-radius: var(--v2-radius-xs);
  }

  .status-pill-dot {
    width: 6px;
    height: 6px;
    background: var(--blue);
    border-radius: var(--v2-radius-full);
  }

  .status-rows {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin: 0;
  }

  .status-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .status-label {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .status-value {
    margin: 0;
    font-size: 15px;
    font-weight: 500;
    line-height: 1.3;
    color: var(--ink);
  }

  /* Section heads sit on the grid bg directly - they're the stage,
   * not actors. Eyebrow + h2 + lede stack with the same vertical
   * rhythm as v1 to keep brand voice. */
  .services-block {
    margin-top: var(--v2-space-2xl);
  }

  .section-head {
    max-width: 60ch;
    margin: 0 auto var(--v2-space-lg);
    text-align: center;
  }

  .eyebrow-section {
    justify-content: center;
    margin-bottom: 14px;
  }

  .section-head h2 {
    margin: 0 0 12px;
    font-family: var(--display);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 500;
    line-height: 1.1;
    color: var(--ink);
    letter-spacing: -0.025em;
    text-wrap: balance;
  }

  .section-lede {
    max-width: 52ch;
    margin: 0 auto;
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-2);
  }

  /* 2x2 grid on desktop, single column from 880px down. Gap shows
   * the dot grid through, which is the whole point. */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--v2-space-md);
  }

  /* Service panel is opaque idle, lifts into the same liquid-glass
   * paint as .hero-status on hover (translucent --v2-panel + blur +
   * lit-edge inset + soft border) and reveals the spotlight pseudos
   * defined alongside .hero-status further down. No translateY -
   * panel stays planted, only the surface paint changes. */
  .service-panel {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: var(--v2-space-lg);
    background: var(--v2-panel);
    border: 1px solid var(--v2-line);
    border-radius: var(--v2-radius-md);
    isolation: isolate;
    -webkit-backdrop-filter: none;
    backdrop-filter: none;
    transition:
      background 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      -webkit-backdrop-filter 0.3s ease,
      backdrop-filter 0.3s ease;
  }

  .service-panel:hover {
    background: color-mix(in srgb, var(--v2-panel) 55%, transparent);
    border-color: color-mix(in srgb, var(--v2-line) 60%, transparent);
    box-shadow: inset 0 1px 0 light-dark(rgba(255, 255, 255, 0.6), rgba(255, 255, 255, 0.05));
    -webkit-backdrop-filter: saturate(160%) blur(20px);
    backdrop-filter: saturate(160%) blur(20px);
  }

  /* Title row - h3 on the left, ghost number on the right at same
   * baseline. align-items: baseline keeps the typographic line
   * shared even though the number is much larger. */
  .service-head {
    display: flex;
    gap: 16px;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .service-panel h3 {
    margin: 0;
    font-family: var(--display);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  /* Ghost number - large display digit pushed to the right of the
   * title row, faded with opacity so it reads as background rather
   * than competing with the title. Hover bumps it up a notch so the
   * card lights up holistically with the spotlight + glass paint.
   * flex-shrink: 0 prevents the title wrap from squashing it. */
  .service-num {
    flex-shrink: 0;
    font-family: var(--display);
    font-size: 36px;
    font-weight: 400;
    line-height: 1;
    color: var(--muted);
    letter-spacing: -0.02em;
    opacity: 0.3;
    transition: opacity 0.3s ease;
  }

  .service-panel:hover .service-num {
    opacity: 0.6;
  }

  @media (prefers-reduced-motion: reduce) {
    .service-num {
      transition: none;
    }
  }

  .service-panel p {
    margin: 0 0 20px;
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-2);
  }

  /* Tag chips are small mono badges, transparent bg with a thin
   * border so they read as separate elements on the panel without
   * fighting the panel's own border. */
  .service-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 0;
    margin: auto 0 0;
    list-style: none;
  }

  .chip {
    padding: 4px 10px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-2);
    background: transparent;
    border: 1px solid var(--v2-line);
    border-radius: var(--v2-radius-xs);
  }

  /* How I work — five steps as a vertical column of panels. Same
   * panel surface as services but full-width and stacked, so the
   * grid bg shows through on the gaps. */
  .how-block {
    margin-top: var(--v2-space-2xl);
  }

  .how-steps {
    display: flex;
    flex-direction: column;
    gap: var(--v2-space-md);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .step-panel {
    padding: var(--v2-space-lg);
    background: var(--v2-panel);
    border: 1px solid var(--v2-line);
    border-radius: var(--v2-radius-md);
    transition: border-color 0.2s ease;
  }

  .step-panel:hover {
    border-color: color-mix(in srgb, var(--blue) 30%, var(--v2-line));
  }

  .step-head {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    margin-bottom: 12px;
  }

  .step-num {
    padding: 4px 10px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--blue);
    letter-spacing: 0.1em;
    background: var(--blue-wash);
    border-radius: var(--v2-radius-xs);
  }

  .step-panel h3 {
    flex: 1;
    margin: 0;
    font-family: var(--display);
    font-size: 20px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  .step-badge {
    padding: 4px 10px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
    background: transparent;
    border: 1px solid var(--v2-line);
    border-radius: var(--v2-radius-xs);
  }

  .step-desc {
    max-width: 70ch;
    margin: 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink-2);
  }

  /* Experience — top 4 roles as panels stacked vertically. Same
   * surface as how-i-work steps; head row puts company on the left,
   * duration badge on the right (matches the step-panel pattern so
   * the eye learns the layout once). */
  .exp-block {
    margin-top: var(--v2-space-2xl);
  }

  .exp-list {
    display: flex;
    flex-direction: column;
    gap: var(--v2-space-md);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .exp-panel {
    padding: var(--v2-space-lg);
    background: var(--v2-panel);
    border: 1px solid var(--v2-line);
    border-radius: var(--v2-radius-md);
    transition: border-color 0.2s ease;
  }

  .exp-panel:hover {
    border-color: color-mix(in srgb, var(--blue) 30%, var(--v2-line));
  }

  /* Current role gets a subtle blue-tinted left border so the eye
   * can pick it out without reading the badge. */
  .exp-panel.exp-now {
    border-left: 3px solid var(--blue);
  }

  .exp-head {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .exp-panel h3 {
    margin: 0;
    font-family: var(--display);
    font-size: 20px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  .exp-meta {
    padding: 4px 10px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
    background: transparent;
    border: 1px solid var(--v2-line);
    border-radius: var(--v2-radius-xs);
  }

  /* "teraz" badge for the current role - filled blue-wash to match
   * the step number pill, signals "active" without shouting. */
  .exp-meta-now {
    color: var(--blue);
    background: var(--blue-wash);
    border-color: transparent;
  }

  .exp-role {
    margin-bottom: 12px;
    font-size: 14px;

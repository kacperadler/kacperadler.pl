---
import { getCollection } from "astro:content";
import type { ImageMetadata } from "astro";
import { Icon } from "astro-icon/components";
import apptensionLogo from "@/assets/experience/apptension.svg";
import energiadirectLogo from "@/assets/experience/energiadirect.svg";
import helpfindLogo from "@/assets/experience/helpfind.svg";
import paylooLogo from "@/assets/experience/payloo.jpeg";
import pwcLogo from "@/assets/experience/pwc.svg";
import rexLogo from "@/assets/experience/rex.svg";
import ContactForm from "@/components/contact/contact-form.astro";
import Button from "@/components/ui/button.astro";
import { siteConfig } from "@/data/site-config";
import V2Layout from "@/layouts/v2-layout.astro";

/* /v2 - redesign track. noindex via V2Layout default, sitemap
 * exclusion lives in astro.config.ts.
 *
 * Faza 1: hero. Faza 2: services + how-i-work + experience + contact.
 * Section heads stay text-on-bg (the grid is the stage); only
 * content blocks become panels. */

const services = (await getCollection("services")).sort((a, b) => a.data.order - b.data.order);

/* Experience renders as a "Współpracowałem z" logo wall. logoBySlug maps
 * collection ids (filename without .json) to imported image assets;
 * entries without a matching logo are filtered out so we don't render
 * empty cards. */
const logoBySlug: Record<string, ImageMetadata> = {
  apptension: apptensionLogo,
  energiadirect: energiadirectLogo,
  helpfind: helpfindLogo,
  payloo: paylooLogo,
  pwc: pwcLogo,
  rex: rexLogo,
};

const experience = (await getCollection("experience"))
  .filter((item) => Boolean(logoBySlug[item.id]))
  .sort((a, b) => a.data.order - b.data.order);

interface FlowStep {
  badge: string;
  description: string;
  icon: string;
  num: string;
  title: string;
}

const steps: readonly FlowStep[] = [
  {
    num: "01",
    icon: "lucide:messages-square",
    title: "Rozmowa",
    description:
      "Krótkie spotkanie albo wymiana maili - co Ci wygodniej. Opowiadasz, co chcesz zbudować i po co; ja zadaję pytania, czasem niewygodne.",
    badge: "~ 30 min",
  },
  {
    num: "02",
    icon: "lucide:clipboard-list",
    title: "Plan i wycena",
    description:
      "Po rozmowie dostajesz krótki dokument: co robimy, w jakiej kolejności, ile to zajmie i ile kosztuje. Bez ukrytych kosztów, bez niespodzianek w trakcie.",
    badge: "2–3 dni",
  },
  {
    num: "03",
    icon: "lucide:code",
    title: "Realizacja",
    description:
      "Pracuję małymi etapami - co tydzień widzisz coś, co działa, nie obrazek. Gdy coś idzie nie tak, łatwiej to zauważyć i poprawić.",
    badge: "podział na etapy",
  },
  {
    num: "04",
    icon: "lucide:message-circle",
    title: "Feedback i iteracje",
    description:
      "Nie musisz znać się na technologii. Mówisz „to powinno być szybsze”, „tu brakuje jasności”, „zmieńmy kolejność” - ja tłumaczę to na konkretne zmiany i pokazuję efekt.",
    badge: "na bieżąco",
  },
  {
    num: "05",
    icon: "lucide:rocket",
    title: "Wdrożenie i opieka",
    description:
      "Po wdrożeniu zostaje monitoring. Łapię błędy zanim staną się problemem, mierzę performance, przygotowuję poprawki. Twój produkt nie jest sam.",
    badge: "+ nadzór",
  },
];
---

<V2Layout title="v2 redesign">
  <main id="top" class="v2-main">
    <div class="v2-container">
      <section class="hero-panel">
        <div class="hero-grid">
          <div class="hero-text">
            <p class="eyebrow">
              <span class="dot" aria-hidden="true"></span>
              {siteConfig.role} · Polska
            </p>

            <h1>
              Buduję <em>interfejsy</em> dla produktów,<br />
              z których ludzie korzystają codziennie.
            </h1>

            <p class="hero-sub">
              Aplikacje mobilne, webowe, narzędzia B2B i landing pages - od architektury po deploy.
              Pracuję w sprintach, async, z zespołami produktowymi w PL/EU.
            </p>

            <div class="ctas">
              <Button variant="primary" href="#contact" icon="lucide:arrow-right">
                Porozmawiajmy
              </Button>
              <Button variant="ghost" href="#how">Zobacz proces</Button>
            </div>
          </div>

          <aside class="hero-status" aria-label="Stan obecny" data-spotlight>
            <span class="status-pill">
              <span class="status-pill-dot" aria-hidden="true"></span>
              Otwarty na nowe współprace
            </span>

            <dl class="status-rows">
              <div class="status-row">
                <dt class="status-label">Stack</dt>
                <dd class="status-value">React · TypeScript · Astro</dd>
              </div>
              <div class="status-row">
                <dt class="status-label">Teraz</dt>
                <dd class="status-value">Frontend dev w&nbsp;ReX</dd>
              </div>
              <div class="status-row">
                <dt class="status-label">Odpowiadam</dt>
                <dd class="status-value">zwykle w&nbsp;24h</dd>
              </div>
            </dl>
          </aside>
        </div>
      </section>

      <section class="services-block" id="services">
        <header class="section-head">
          <p class="eyebrow eyebrow-section">Usługi</p>
          <h2>
            Obszary w&nbsp;których <em>działam</em>.
          </h2>
          <p class="section-lede">
            Moje doświadczenie pozwala mi na pracę w wielu technologiach<br />i projektach.
          </p>
        </header>

        <div class="services-grid">
          {
            services.map((service, idx) => (
              <article class="service-panel" data-spotlight>
                <header class="service-head">
                  <h3>{service.data.title}</h3>
                  <span aria-hidden="true" class="service-num">
                    {String(idx + 1).padStart(2, "0")}
                  </span>
                </header>
                <p>{service.data.description}</p>
                <ul class="service-tags">
                  {service.data.tags.map((tag) => (
                    <li class="chip">{tag}</li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </section>

      <section class="how-block" id="how">
        <header class="section-head">
          <p class="eyebrow eyebrow-section">Proces</p>
          <h2>
            Od <em>rozmowy</em> do <em>produktu</em>.
          </h2>
          <p class="section-lede">
            Biorąc pod uwagę Twoje potrzeby, skupiam się na znalezieniu najlepszego rozwiązania dla
            Ciebie.
          </p>
        </header>

        <ol class="how-steps">
          {
            steps.map((step) => (
              <li class="step-item">
                <div aria-hidden="true" class="step-marker">
                  <span class="step-dot">{step.num}</span>
                </div>
                <article class="step-panel" data-spotlight>
                  <header class="step-head">
                    <Icon aria-hidden="true" class="step-icon" name={step.icon} />
                    <h3>{step.title}</h3>
                    <span class="step-badge">{step.badge}</span>
                  </header>
                  <p class="step-desc">{step.description}</p>
                </article>
              </li>
            ))
          }
        </ol>
      </section>

      <section class="exp-block" id="experience">
        <header class="section-head">
          <p class="eyebrow eyebrow-section">Współprace</p>
          <h2>
            Realizacje i&nbsp;<em>współprace</em>.
          </h2>
          <p class="section-lede">
            Tworzyłem projekty i współpracowałem z firmami z różnych branż - od korporacji po
            side-projekty.
          </p>
        </header>

        <ul class="exp-list">
          {
            experience.map((item) => {
              // Filter above guarantees logo exists; assert for TS.
              const logo = logoBySlug[item.id] as ImageMetadata;
              const startYear = item.data.startDate.slice(0, 4);
              const endYear = item.data.endDate?.slice(0, 4);
              // Badge label: current → "teraz"; badge override → that
              // label; else year range. Filled (.exp-meta-now styling)
              // when current OR badge override is set, otherwise the
              // muted outline year range.
              let metaLabel: string;
              let metaFilled: boolean;
              if (item.data.current) {
                metaLabel = "teraz";
                metaFilled = true;
              } else if (item.data.badge) {
                metaLabel = item.data.badge;
                metaFilled = true;
              } else {
                metaLabel = `${startYear}–${endYear}`;
                metaFilled = false;
              }
              return (
                <li class="exp-panel" data-spotlight>
                  <header class="exp-head">
                    <div class="exp-logo-wrap">
                      <img
                        alt={item.data.company}
                        class="exp-logo"
                        height={logo.height}
                        src={logo.src}
                        width={logo.width}
                      />
                    </div>
                    <span class:list={["exp-meta", { "exp-meta-now": metaFilled }]}>
                      {metaLabel}
                    </span>
                  </header>
                  <h3>{item.data.company}</h3>
                  <div class="exp-role">{item.data.role}</div>
                  <p class="exp-desc">{item.data.description}</p>
                </li>
              );
            })
          }
        </ul>
      </section>

      <section class="contact-block" id="contact">
        <header class="section-head">
          <p class="eyebrow eyebrow-section">Kontakt</p>
          <h2>
            Porozmawiajmy o&nbsp;Twoim <em>pomyśle</em>.
          </h2>
          <p class="section-lede">
            Napisz krótko: co budujesz, w jakim terminie i co Cię blokuje. Odpowiem w ciągu 24
            godzin.
          </p>
        </header>

        <div class="contact-grid">
          <div class="contact-links">
            <a class="v2-contact-link" data-spotlight href={`mailto:${siteConfig.email}`}>
              <Icon aria-hidden="true" class="v2-contact-icon" name="lucide:mail" />
              <span class="v2-contact-label">Email</span>
              <span class="v2-contact-value">{siteConfig.email}</span>
            </a>
            <a
              class="v2-contact-link"
              data-spotlight
              href={siteConfig.social.linkedin}
              rel="noopener"
              target="_blank"
            >
              <Icon aria-hidden="true" class="v2-contact-icon" name="lucide:linkedin" />
              <span class="v2-contact-label">LinkedIn</span>
              <span class="v2-contact-value">/in/kacperadler</span>
            </a>
          </div>

          <div class="contact-form-host" data-spotlight>
            <ContactForm />
          </div>
        </div>
      </section>
    </div>
  </main>
</V2Layout>

<style>
  .v2-main {
    padding: 48px 0 96px;
  }

  .v2-container {
    max-width: var(--container);
    padding: 0 var(--v2-space-md);
    margin: 0 auto;
  }

  /* Hero - intentionally NO outer panel. The headline column floats
   * directly on the dot-grid + ribbons (apptension/firecrawl read);
   * only the status card opts into a surface, and that surface is
   * glass so the ribbon motion bleeds through it like in the header. */
  .hero-panel {
    padding: var(--v2-space-xl) 0;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: var(--v2-space-xl);
    align-items: center;
  }

  .hero-text {
    min-width: 0;
  }

  /* Status card - liquid glass, mirroring the header chrome. Translucent
   * --v2-panel + backdrop-filter blur, lit-edge inset highlight, soft
   * line border. Reads as "atmosphere-floating UI" rather than content
   * panel. Future demo block can live in this slot with the same skin.
   *
   * Two pseudo-elements layered on top render the spotlight effect:
   *   ::before is a soft white wash centered at (--mx, --my) - "the
   *     panel brightens under your cursor".
   *   ::after is a navy radial gradient masked via mask-composite to
   *     a 1px ring - "the border lights up near the cursor".
   *   Both fade in on :hover. --mx / --my are set by spotlight.ts;
   *   default 50%/50% so the resting paint (which is invisible
   *   anyway because opacity:0) doesn't shift on first move.
   *
   * isolation: isolate gives the pseudos their own stacking context
   * so they paint cleanly above the panel bg. */
  .hero-status {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--v2-space-md);
    padding: var(--v2-space-lg);
    background: color-mix(in srgb, var(--v2-panel) 55%, transparent);
    border: 1px solid color-mix(in srgb, var(--v2-line) 60%, transparent);
    border-radius: var(--v2-radius-md);
    box-shadow: inset 0 1px 0 light-dark(rgba(255, 255, 255, 0.6), rgba(255, 255, 255, 0.05));
    isolation: isolate;
    -webkit-backdrop-filter: saturate(160%) blur(20px);
    backdrop-filter: saturate(160%) blur(20px);
    transition: background 0.3s ease;
  }

  /* On hover both glass cards bump panel translucency 55% → 65% so the
   * surface reads as "lit up" overall. The cool-blue tint comes from
   * the ::before pseudo's flat blue layer (kicks in via opacity 0→1
   * along with the cursor wash). */
  .hero-status:hover,
  .service-panel:hover,
  .step-panel:hover,
  .exp-panel:hover,
  .v2-contact-link:hover,
  .contact-form-host:hover,
  .contact-form-host:has(input[type="email"]:focus, textarea:focus),
  .contact-form-host:has([data-state="success"]) {
    background: color-mix(in srgb, var(--v2-panel) 65%, transparent);
  }

  /* Spotlight pattern shared across all glass cards: .hero-status (always
   * glass), .service-panel + .step-panel + .exp-panel + .v2-contact-link
   * + .contact-form-host (opaque idle, glass + spotlight on hover). Same
   * gradient values, same opacity transition; only the surface treatment
   * around the pseudos differs. */
  .hero-status > *,
  .service-panel > *,
  .step-panel > *,
  .exp-panel > *,
  .v2-contact-link > *,
  .contact-form-host > * {
    position: relative;
    z-index: 1;
  }

  .hero-status::before,
  .hero-status::after,
  .service-panel::before,
  .service-panel::after,
  .step-panel::before,
  .step-panel::after,
  .exp-panel::before,
  .exp-panel::after,
  .v2-contact-link::before,
  .v2-contact-link::after,
  .contact-form-host::before,
  .contact-form-host::after {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: "";
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  /* Surface wash - 220px radius radial-gradient at (--mx, --my) layered
   * over a flat navy tint (#2a4d7f, the darker --blue-2 light-mode
   * value, kept literal because v2 dark-only resolves --blue-2 to a
   * lighter shade). The radial-gradient is the cursor-follow ambient
   * lift; the flat layer below tints the whole panel cool-navy when
   * ::before fades in (opacity 0→1 on hover). One pseudo for both
   * layers means the tint fades in smoothly along with the wash. */
  .hero-status::before,
  .service-panel::before,
  .step-panel::before,
  .exp-panel::before,
  .v2-contact-link::before,
  .contact-form-host::before {
    z-index: 0;
    background:
      radial-gradient(
        220px circle at var(--mx, 50%) var(--my, 50%),
        color-mix(in srgb, white 4%, transparent),
        transparent 55%
      ),
      color-mix(in srgb, #2a4d7f 8%, transparent);
  }

  /* Border ring - navy gradient painted across the whole pseudo, then
   * masked via mask-composite: exclude to a 1px ring (whole-box mask
   * MINUS content-box mask = padding strip). Result: only the 1px
   * perimeter is painted, brightest near the cursor. -webkit-mask-
   * composite: xor is the legacy syntax for the same effect. */
  .hero-status::after,
  .service-panel::after,
  .step-panel::after,
  .exp-panel::after,
  .v2-contact-link::after,
  .contact-form-host::after {
    z-index: 2;
    padding: 1px;
    background: radial-gradient(
      160px circle at var(--mx, 50%) var(--my, 50%),
      color-mix(in srgb, var(--blue) 50%, transparent),
      transparent 55%
    );
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
  }

  .hero-status:hover::before,
  .hero-status:hover::after,
  .service-panel:hover::before,
  .service-panel:hover::after,
  .step-panel:hover::before,
  .step-panel:hover::after,
  .exp-panel:hover::before,
  .exp-panel:hover::after,
  .v2-contact-link:hover::before,
  .v2-contact-link:hover::after,
  .contact-form-host:hover::before,
  .contact-form-host:hover::after,
  .contact-form-host:has(input[type="email"]:focus, textarea:focus)::before,
  .contact-form-host:has(input[type="email"]:focus, textarea:focus)::after,
  .contact-form-host:has([data-state="success"])::before,
  .contact-form-host:has([data-state="success"])::after {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-status::before,
    .hero-status::after,
    .service-panel::before,
    .service-panel::after,
    .step-panel::before,
    .step-panel::after,
    .exp-panel::before,
    .exp-panel::after,
    .v2-contact-link::before,
    .v2-contact-link::after,
    .contact-form-host::before,
    .contact-form-host::after {
      transition: none;
    }
  }

  /* Static blue-wash pill - intentionally not pulsing. The hero
   * eyebrow already carries the only foreground "live" signal. */
  .status-pill {
    display: inline-flex;
    gap: 8px;
    align-items: center;
    align-self: flex-start;
    padding: 6px 12px;
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--blue);
    background: var(--blue-wash);
    border-radius: var(--v2-radius-xs);
  }

  .status-pill-dot {
    width: 6px;
    height: 6px;
    background: var(--blue);
    border-radius: var(--v2-radius-full);
  }

  .status-rows {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin: 0;
  }

  .status-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .status-label {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .status-value {
    margin: 0;
    font-size: 15px;
    font-weight: 500;
    line-height: 1.3;
    color: var(--ink);
  }

  /* Section heads sit on the grid bg directly - they're the stage,
   * not actors. Eyebrow + h2 + lede stack with the same vertical
   * rhythm as v1 to keep brand voice. */
  .services-block {
    margin-top: var(--v2-space-2xl);
  }

  .section-head {
    max-width: 60ch;
    margin: 0 auto var(--v2-space-lg);
    text-align: center;
  }

  .eyebrow-section {
    justify-content: center;
    margin-bottom: 14px;
  }

  .section-head h2 {
    margin: 0 0 12px;
    font-family: var(--display);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 500;
    line-height: 1.1;
    color: var(--ink);
    letter-spacing: -0.025em;
    text-wrap: balance;
  }

  .section-lede {
    max-width: 52ch;
    margin: 0 auto;
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-2);
  }

  /* 2x2 grid on desktop, single column from 880px down. Gap shows
   * the dot grid through, which is the whole point. */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--v2-space-md);
  }

  /* Service panel is opaque idle, lifts into the same liquid-glass
   * paint as .hero-status on hover (translucent --v2-panel + blur +
   * lit-edge inset + soft border) and reveals the spotlight pseudos
   * defined alongside .hero-status further down. No translateY -
   * panel stays planted, only the surface paint changes. */
  .service-panel {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: var(--v2-space-lg);
    background: var(--v2-panel);
    border: 1px solid var(--v2-line);
    border-radius: var(--v2-radius-md);
    isolation: isolate;
    -webkit-backdrop-filter: none;
    backdrop-filter: none;
    transition:
      background 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      -webkit-backdrop-filter 0.3s ease,
      backdrop-filter 0.3s ease;
  }

  .service-panel:hover {
    border-color: color-mix(in srgb, var(--v2-line) 60%, transparent);
    box-shadow: inset 0 1px 0 light-dark(rgba(255, 255, 255, 0.6), rgba(255, 255, 255, 0.05));
    -webkit-backdrop-filter: saturate(160%) blur(20px);
    backdrop-filter: saturate(160%) blur(20px);
  }

  /* Title row - h3 on the left, ghost number on the right at same
   * baseline. align-items: baseline keeps the typographic line
   * shared even though the number is much larger. */
  .service-head {
    display: flex;
    gap: 16px;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .service-panel h3 {
    margin: 0;
    font-family: var(--display);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  /* Ghost number - large display digit pushed to the right of the
   * title row, faded with opacity so it reads as background rather
   * than competing with the title. Hover bumps it up a notch so the
   * card lights up holistically with the spotlight + glass paint.
   * flex-shrink: 0 prevents the title wrap from squashing it. */
  .service-num {
    flex-shrink: 0;
    font-family: var(--display);
    font-size: 36px;
    font-weight: 400;
    line-height: 1;
    color: var(--muted);
    letter-spacing: -0.02em;
    opacity: 0.3;
    transition: opacity 0.3s ease;
  }

  .service-panel:hover .service-num {
    opacity: 0.6;
  }

  @media (prefers-reduced-motion: reduce) {
    .service-num {
      transition: none;
    }
  }

  .service-panel p {
    margin: 0 0 20px;
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-2);
  }

  /* Tag chips are small mono badges, transparent bg with a thin
   * border so they read as separate elements on the panel without
   * fighting the panel's own border. */
  .service-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 0;
    margin: auto 0 0;
    list-style: none;
  }

  .chip {
    padding: 4px 10px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-2);
    background: transparent;
    border: 1px solid var(--v2-line);
    border-radius: var(--v2-radius-xs);
  }


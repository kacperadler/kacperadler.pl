---
import BaseLayout from "@/layouts/base-layout.astro";

interface Props {
  frontmatter: {
    title: string;
    description?: string;
    lastUpdated: string;
  };
}

const { frontmatter } = Astro.props;

const lastUpdatedFormatted = new Date(frontmatter.lastUpdated).toLocaleDateString("pl-PL", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <main class="legal" id="top">
    <article class="container">
      <header class="legal-head">
        <p class="legal-eyebrow">Informacja prawna</p>
        <h1>{frontmatter.title}</h1>
        <p class="legal-meta">
          Ostatnia aktualizacja:
          <time datetime={frontmatter.lastUpdated}>{lastUpdatedFormatted}</time>
        </p>
      </header>
      <div class="prose">
        <slot />
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  .legal {
    padding: 80px 0 60px;
  }

  .legal-head {
    max-width: 70ch;
    margin: 0 auto 48px;
  }

  .legal-eyebrow {
    margin: 0 0 12px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--blue);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .legal-head h1 {
    margin: 0 0 12px;
    font-family: var(--display);
    font-size: clamp(32px, 4vw, 44px);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .legal-meta {
    margin: 0;
    font-family: var(--mono);
    font-size: 13px;
    color: var(--muted);
  }

  /* Prose styles target child elements rendered from the markdown. We
   * use :global() because Astro scopes class selectors to the
   * component, but markdown emits raw tags (h2/p/ul/...) that need
   * unscoped rules. */
  .prose {
    max-width: 70ch;
    margin: 0 auto;
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink-2);
  }

  .prose :global(h2) {
    margin: 40px 0 12px;
    font-family: var(--display);
    font-size: 20px;
    font-weight: 500;
    line-height: 1.3;
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  .prose :global(h3) {
    margin: 28px 0 10px;
    font-family: var(--display);
    font-size: 16px;
    font-weight: 500;
    color: var(--ink);
  }

  .prose :global(p) {
    margin: 0 0 16px;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5em;
    margin: 0 0 16px;
  }

  .prose :global(li) {
    margin-bottom: 6px;
  }

  .prose :global(strong) {
    font-weight: 500;
    color: var(--ink);
  }

  .prose :global(a) {
    color: var(--blue);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(code) {
    padding: 2px 6px;
    font-family: var(--mono);
    font-size: 0.92em;
    color: var(--ink);
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 4px;
  }
</style>

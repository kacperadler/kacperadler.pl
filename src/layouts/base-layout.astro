---
import { ClientRouter } from "astro:transitions";
import BaseHead from "@/components/layout/base-head.astro";
import EuFunding from "@/components/layout/eu-funding.astro";
import Footer from "@/components/layout/footer.astro";
import Header from "@/components/layout/header.astro";
import MobileSheet from "@/components/layout/mobile-sheet.astro";
import { siteConfig } from "@/data/site-config";
import "@/styles/tokens.css";
import "@/styles/global.css";

/* Base layout - paints the dark substrate + dot grid + drifting navy ribbons
 * behind every page. Header / Footer / MobileSheet pick up liquid-glass
 * paint from the overrides at the bottom of this file so the ribbon motion
 * bleeds through them. */

interface Props {
  description?: string;
  noindex?: boolean;
  ogImage?: string;
  title?: string;
}

interface Ribbon {
  right: number;
  rotate: number;
  variant: "accent" | "wash";
}

const { title, description, ogImage, noindex } = Astro.props;

/* Six navy ribbons drift over the dot grid. Each is a 0×120vh element
 * whose entire paint comes from box-shadow (see .ribbon CSS). Phase delays
 * are spread evenly across the cycle so the field reads as multidirectional
 * drift, never a synchronized wave. */
const ribbons: readonly Ribbon[] = [
  { right: 78, rotate: 14, variant: "accent" },
  { right: 60, rotate: -10, variant: "wash" },
  { right: 42, rotate: 18, variant: "accent" },
  { right: 24, rotate: -6, variant: "wash" },
  { right: 6, rotate: 12, variant: "accent" },
  { right: -12, rotate: -8, variant: "wash" },
];

const ribbonStyles = ribbons.map((r, i) => {
  const duration = 8 + i * 1.5;
  const delay = -((i / ribbons.length) * duration);
  return {
    ...r,
    style: `right: ${r.right}vw; --ribbon-rot: rotate(${r.rotate}deg); animation-duration: ${duration}s; animation-delay: ${delay.toFixed(2)}s;`,
  };
});
---

<!doctype html>
<html lang={siteConfig.lang}>
  <head>
    <BaseHead title={title} description={description} ogImage={ogImage} noindex={noindex} />
    <ClientRouter />
  </head>
  <body>
    <a href="#top" class="skip-link">Przejdź do treści</a>

    <div class="bg-stage" aria-hidden="true">
      {
        ribbonStyles.map((r) => (
          <div class:list={["ribbon", `ribbon-${r.variant}`]} style={r.style} />
        ))
      }
      <div class="fade-h"></div>
      <div class="fade-v"></div>
    </div>

    <div class="page-shell">
      <Header />
      <slot />
      <Footer />
      <EuFunding />
    </div>

    <MobileSheet />
  </body>
</html>

<script>
  import "@/scripts/contact-form.ts";
  import "@/scripts/mobile-sheet.ts";
  import "@/scripts/nav-active.ts";
  import "@/scripts/nav-scroll.ts";
  import "@/scripts/spotlight.ts";
</script>

<style is:global>
  /* Page-shell stacks above the fixed bg-stage. Position:relative + explicit
   * z-index is what keeps the shell on top of the ribbons (which paint at
   * z-index auto behind .page-shell). pointer-events on .bg-stage are off
   * so clicks fall through. */
  .page-shell {
    position: relative;
    z-index: 1;
  }

  /* Fixed atmosphere stage - holds the dot grid + ribbons. Nothing in here
   * scrolls. No negative z-index because that would tuck this BEHIND the
   * body's fallback bg paint; the DOM order + .page-shell's stacking
   * context is what keeps content on top. */
  .bg-stage {
    position: fixed;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    background-color: var(--v2-bg);
    background-image: radial-gradient(circle at 1px 1px, var(--v2-grid) 1px, transparent 0);
    background-size: 24px 24px;
  }

  /* Each ribbon is a 0×120vh element whose box-shadow paints the coloured
   * slab. will-change keeps it on its own GPU layer so the compositor
   * doesn't throttle the animation when nothing in the 0×0 bounding box
   * visibly changes. */
  .ribbon {
    position: absolute;
    top: -10vh;
    width: 0;
    height: 120vh;
    transform: var(--ribbon-rot) translateZ(0);
    transform-origin: top right;
    animation-name: v2-drift;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
    will-change: transform;
  }

  @keyframes v2-drift {
    0%,
    100% {
      transform: var(--ribbon-rot) translateZ(0) translateX(-40px);
    }
    50% {
      transform: var(--ribbon-rot) translateZ(0) translateX(40px);
    }
  }

  .ribbon-accent {
    box-shadow:
      -120px 0 80px 40px var(--v2-bg),
      -30px 0 60px 30px color-mix(in srgb, var(--blue) 55%, transparent),
      30px 0 80px 40px color-mix(in srgb, var(--blue) 35%, transparent),
      120px 0 80px 40px var(--v2-bg);
  }

  .ribbon-wash {
    box-shadow:
      -120px 0 80px 40px var(--v2-bg),
      -30px 0 70px 35px color-mix(in srgb, var(--blue-2) 30%, transparent),
      30px 0 90px 45px color-mix(in srgb, var(--blue) 20%, transparent),
      120px 0 80px 40px var(--v2-bg);
  }

  .fade-h {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100vw;
    height: 0;
    box-shadow: 0 0 50vh 30vh var(--v2-bg);
  }

  .fade-v {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 100vh;
    box-shadow: 0 0 35vw 20vw var(--v2-bg);
  }

  @media (prefers-reduced-motion: reduce) {
    .ribbon {
      animation: none;
    }
  }

  /* Liquid-glass header. Atmosphere-floating chrome that lets the ribbon
   * drift bleed through. Inset top hairline reads as iOS-style "lit edge". */
  .nav-wrap {
    background: color-mix(in srgb, var(--v2-panel) 55%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--v2-line) 60%, transparent);
    box-shadow: inset 0 1px 0 light-dark(rgba(255, 255, 255, 0.6), rgba(255, 255, 255, 0.05));
    -webkit-backdrop-filter: saturate(160%) blur(20px);
    backdrop-filter: saturate(160%) blur(20px);
  }

  /* Once the user scrolls past the hero, snap to a slightly more opaque
   * + tinted state so the header reads as "fixed UI" rather than the
   * floaty intro state. Border firms up too. */
  .nav-wrap.scrolled {
    background: color-mix(in srgb, var(--v2-panel) 75%, transparent);
    border-bottom-color: var(--v2-line);
  }

  /* Footer matches the header chrome at the other end of the page. */
  .site-footer {
    background: color-mix(in srgb, var(--v2-panel) 55%, transparent);
    border-top: 1px solid color-mix(in srgb, var(--v2-line) 60%, transparent);
    box-shadow: inset 0 1px 0 light-dark(rgba(255, 255, 255, 0.6), rgba(255, 255, 255, 0.05));
    -webkit-backdrop-filter: saturate(160%) blur(20px);
    backdrop-filter: saturate(160%) blur(20px);
  }

  /* Mobile sheet is mocniejszy (70% panel) than header/footer because full-
   * screen overlay needs better text readability over the ribbons. */
  .sheet {
    background: color-mix(in srgb, var(--v2-panel) 70%, transparent);
    box-shadow: inset 0 1px 0 light-dark(rgba(255, 255, 255, 0.6), rgba(255, 255, 255, 0.05));
    -webkit-backdrop-filter: saturate(160%) blur(20px);
    backdrop-filter: saturate(160%) blur(20px);
  }

  /* Brand mark in the header picks up sm radius so it harmonises with the
   * rounded panels below. */
  .mark {
    border-radius: var(--v2-radius-sm);
  }
</style>

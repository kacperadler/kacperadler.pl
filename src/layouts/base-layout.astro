---
import { ClientRouter } from "astro:transitions";
import BaseHead from "@/components/layout/base-head.astro";
import Footer from "@/components/layout/footer.astro";
import Header from "@/components/layout/header.astro";
import MobileSheet from "@/components/layout/mobile-sheet.astro";
import ThemeFab from "@/components/theme/theme-fab.astro";
import { siteConfig } from "@/data/site-config";
import "@/styles/tokens.css";
import "@/styles/global.css";

interface Props {
  description?: string;
  noindex?: boolean;
  ogImage?: string;
  title?: string;
}

const { title, description, ogImage, noindex } = Astro.props;
---

<!doctype html>
<html lang={siteConfig.lang}>
  <head>
    <BaseHead title={title} description={description} ogImage={ogImage} noindex={noindex} />
    <ClientRouter />
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
    <MobileSheet />
    <ThemeFab />
  </body>
</html>

<script>
  import "@/scripts/contact-form.ts";
  import "@/scripts/flow-cycle.ts";
  import "@/scripts/mobile-sheet.ts";
  import "@/scripts/nav-active.ts";
  import "@/scripts/nav-scroll.ts";
  import "@/scripts/reveal.ts";
  import "@/scripts/timeline-collapse.ts";
</script>

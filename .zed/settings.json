{
  "$schema": "https://zed.dev/schema/settings/v0.2.0.json",

  "format_on_save": "on",

  "languages": {
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "bunx",
          "arguments": [
            "biome",
            "check",
            "--write",
            "--stdin-file-path={buffer_path}"
          ]
        }
      }
    },
    "TSX": {
      "formatter": {
        "external": {
          "command": "bunx",
          "arguments": [
            "biome",
            "check",
            "--write",
            "--stdin-file-path={buffer_path}"
          ]
        }
      }
    },
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "bunx",
          "arguments": [
            "biome",
            "check",
            "--write",
            "--stdin-file-path={buffer_path}"
          ]
        }
      }
    },
    "JSX": {
      "formatter": {
        "external": {
          "command": "bunx",
          "arguments": [
            "biome",
            "check",
            "--write",
            "--stdin-file-path={buffer_path}"
          ]
        }
      }
    },
    "JSON": {
      "formatter": {
        "external": {
          "command": "bunx",
          "arguments": [
            "biome",
            "check",
            "--write",
            "--stdin-file-path={buffer_path}"
          ]
        }
      }
    },
    "JSONC": {
      "formatter": {
        "external": {
          "command": "bunx",
          "arguments": [
            "biome",
            "check",
            "--write",
            "--stdin-file-path={buffer_path}"
          ]
        }
      }
    },
    "CSS": {
      "formatter": {
        "external": {
          "command": "bunx",
          "arguments": [
            "biome",
            "check",
            "--write",
            "--stdin-file-path={buffer_path}"
          ]
        }
      }
    },
    "Astro": {
      "formatter": {
        "external": {
          "command": "bunx",
          "arguments": ["prettier", "--stdin-filepath", "{buffer_path}"]
        }
      },
      "tab_size": 2
    },
    "Markdown": {
      "formatter": "language_server",
      "soft_wrap": "preferred_line_length",
      "preferred_line_length": 100
    }
  }
}

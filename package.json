{
  "name": "kacperadler.pl",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint": "ultracite check",
    "format": "ultracite fix && prettier --write \"**/*.astro\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.2.1",
    "astro-icon": "^1.1.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "2.4.14",
    "@iconify-json/lucide": "^1.2.105",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "ultracite": "7.6.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,jsonc,css}": "ultracite fix",
    "*.astro": "prettier --write"
  }
}

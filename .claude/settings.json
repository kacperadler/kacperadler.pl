{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(bun:*)",
      "Bash(bunx:*)",
      "Bash(pnpm:*)",
      "Bash(pnpm dlx:*)",
      "Bash(npx astro:*)",
      "Bash(npx wrangler:*)",
      "Bash(astro:*)",
      "Bash(wrangler:*)",
      "Bash(node --version)",
      "Bash(node -v)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git stash list)",
      "Bash(git remote -v)",
      "Bash(gh repo view:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "WebFetch(domain:docs.astro.build)",
      "WebFetch(domain:astro.build)",
      "WebFetch(domain:developers.cloudflare.com)",
      "WebFetch(domain:www.ultracite.ai)",
      "WebFetch(domain:biomejs.dev)",
      "WebFetch(domain:prettier.io)",
      "WebFetch(domain:lucide.dev)",
      "WebFetch(domain:zod.dev)",
      "WebFetch(domain:nanostores.github.io)",
      "WebFetch(domain:playwright.dev)",
      "WebFetch(domain:vitest.dev)",
      "WebFetch(domain:resend.com)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)"
    ]
  }
}

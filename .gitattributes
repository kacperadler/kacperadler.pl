# Auto-detect text files and normalize EOL to LF on commit.
* text=auto eol=lf

# Binary assets - keep diffs out of the way.
*.woff2 binary
*.woff binary
*.ttf binary
*.otf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary
*.pdf binary

# Generated lockfile - collapse in PR review and exclude from language stats.
bun.lock linguist-generated=true
